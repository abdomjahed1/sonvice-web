			<a href="https://instagram.com/sonvicegroup" target="_blank" rel="noopener noreferrer" class="contact-menu-item w-12 h-12 rounded-full bg-gradient-to-tr from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] hover:brightness-110 shadow-lg flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-300 opacity-0 translate-y-4 scale-75 pointer-events-none relative group" aria-label="Instagram">
				<!-- Tooltip -->
