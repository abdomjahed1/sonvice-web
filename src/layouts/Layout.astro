---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Sonvice Group | Flytt- och städtjänster i Kronoberg/Kalmar",
	description = "Professionella flyttjänster, hemstädning, fönsterputsning och takrengöring i Kronoberg/Kalmar. 100% nöjd-kund-garanti."
} = Astro.props;

const pathname = Astro.url.pathname;
const isEn = pathname.startsWith('/en') || pathname.startsWith('en');

const getLangSwitchUrl = () => {
	const cleanPath = pathname.replace(/\/$/, "");
	if (isEn) {
		if (cleanPath === "/en") return "/";
		if (cleanPath === "/en/about-us") return "/om-oss";
		if (cleanPath === "/en/contact") return "/contact";
		if (cleanPath === "/en/careers") return "/jobba-hos-oss";
		if (cleanPath === "/en/truck-rental") return "/lastbilsuthyrning";
		if (cleanPath === "/en/moving-services") return "/flyttjanster";
		if (cleanPath === "/en/home-cleaning") return "/hemstadning";
		if (cleanPath === "/en/window-cleaning") return "/fonsterputsning";
		if (cleanPath === "/en/roof-cleaning") return "/takrengoring";
		if (cleanPath === "/en/gardening") return "/tradgardsvard";
		return "/";
	} else {
		if (cleanPath === "" || cleanPath === "/") return "/en";
		if (cleanPath === "/om-oss") return "/en/about-us";
		if (cleanPath === "/contact") return "/en/contact";
		if (cleanPath === "/jobba-hos-oss") return "/en/careers";
		if (cleanPath === "/lastbilsuthyrning") return "/en/truck-rental";
		if (cleanPath === "/flyttjanster") return "/en/moving-services";
		if (cleanPath === "/hemstadning") return "/en/home-cleaning";
		if (cleanPath === "/fonsterputsning") return "/en/window-cleaning";
		if (cleanPath === "/takrengoring") return "/en/roof-cleaning";
		if (cleanPath === "/tradgardsvard") return "/en/gardening";
		return "/en";
	}
};
const switchUrl = getLangSwitchUrl();

// --- Global Business Configuration Metadata ---
const COMPANY = {
	name: "Sonvice Group AB",
	orgNr: "559XXX-XXXX", // Ändra till riktigt org.nr vid lansering
	phone: "08-123 45 67",
	phoneLink: "tel:081234567",
	email: "info@sonvicegroup.se",
	address: "Kronoberg/Kalmar, Sverige",
	websiteUrl: "https://sonvicegroup.se",
};

const SITE_URL = COMPANY.websiteUrl;
const canonicalPath = pathname.endsWith('/') && pathname !== '/' ? pathname.slice(0, -1) : pathname;
const canonicalURL = `${SITE_URL}${canonicalPath}`;

// Alternates for SEO Hreflang
const svPath = isEn ? switchUrl : canonicalPath;
const enPath = isEn ? canonicalPath : switchUrl;

const isServicesActive = 
	pathname.includes('/flyttjanster') ||
	pathname.includes('/hemstadning') ||
	pathname.includes('/fonsterputsning') ||
	pathname.includes('/takrengoring') ||
	pathname.includes('/tradgardsvard') ||
	pathname.includes('/lastbilsuthyrning') ||
	pathname.includes('/moving-services') ||
	pathname.includes('/home-cleaning') ||
	pathname.includes('/window-cleaning') ||
	pathname.includes('/roof-cleaning') ||
	pathname.includes('/gardening') ||
	pathname.includes('/truck-rental');

const svURL = `${SITE_URL}${svPath}`;
const enURL = `${SITE_URL}${enPath}`;

const isActive = (path: string) => {
	const current = pathname.replace(/\/$/, "");
	const target = path.replace(/\/$/, "");
	return current === target;
};

const t = isEn ? {
	home: 'Home',
	services: 'Services',
	about: 'About us',
	contact: 'Contact',
	careers: 'Careers',
	truckRental: 'Truck Rental',
	callUs: 'Call us',
	footerDesc: 'Your reliable partner for professional moving, cleaning, window washing, gardening, and roof maintenance across the Kronoberg/Kalmar region.',
	footerServices: 'Services',
	footerCompany: 'Company',
	footerHours: 'Hours',
	svcMoving: 'Moving',
	svcCleaning: 'Cleaning',
	svcWindows: 'Window cleaning',
	svcRoof: 'Roof care',
	svcGarden: 'Gardening',
	svcTruck: 'Truck Rental',
	weekdays: 'Mon – Fri',
	saturday: 'Saturday',
	sunday: 'Sunday',
	closed: 'Closed (Emergency)',
	whatsappTooltip: 'Chat with us',
	langLabel: 'SV',
	contactUs: 'Contact us'
} : {
	home: 'Hem',
	services: 'Tjänster',
	about: 'Om oss',
	contact: 'Kontakt',
	careers: 'Karriär',
	truckRental: 'Lastbilsuthyrning',
	callUs: 'Ring oss',
	footerDesc: 'Din pålitliga partner för professionell flytt, hemstädning, fönsterputsning, trädgårdsvård och takrengöring i hela Kronoberg/Kalmar-området.',
	footerServices: 'Tjänster',
	footerCompany: 'Företag',
	footerHours: 'Öppettider',
	svcMoving: 'Flyttjänster',
	svcCleaning: 'Hemstädning',
	svcWindows: 'Fönsterputsning',
	svcRoof: 'Takrengöring',
	svcGarden: 'Trädgårdsvård',
	svcTruck: 'Lastbilsuthyrning',
	weekdays: 'Mån – Fre',
	saturday: 'Lördag',
	sunday: 'Söndag',
	closed: 'Stängt (Jour)',
	whatsappTooltip: 'Chatta med oss',
	langLabel: 'EN',
	contactUs: 'Kontakta oss'
};
---

<html lang={isEn ? "en" : "sv"}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon-logo.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- SEO Canonical and Alternate Languages (Hreflang) -->
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" hreflang="sv" href={svURL} />
		<link rel="alternate" hreflang="en" href={enURL} />
		<link rel="alternate" hreflang="x-default" href={svURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={`${SITE_URL}/mi-logo.png`} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={`${SITE_URL}/mi-logo.png`} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap">
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" media="print" onload="this.media='all'">
		<noscript>
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap">
		</noscript>
	</head>
	<body class="bg-surface-body text-text-body min-h-screen flex flex-col overflow-x-hidden selection:bg-accent selection:text-white">


		<!-- Scroll Progress Bar -->
		<div id="scroll-progress" class="fixed top-0 left-0 h-[3px] bg-gradient-to-r from-accent via-teal-400 to-emerald-500 z-[9999] transition-all duration-75" style="width: 0%"></div>

		<!-- ═══ HEADER (Scroll-based transparent to glassmorphic transition) ═══ -->
		<header id="main-header" class="fixed top-[3px] left-0 right-0 z-50 w-full bg-transparent border-b border-transparent py-4 transition-all duration-300">
			<div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
				<!-- Logo -->
				<a href={isEn ? "/en" : "/"} class="flex items-center gap-3">
					<img src="/mi-logo.png" alt="" aria-hidden="true" class="h-10 md:h-12 w-auto object-contain transition-transform" width="160" height="48" loading="eager" />
					<span class="text-lg font-bold tracking-tight text-text-heading">Sonvice Group</span>
				</a>

				<!-- Desktop nav -->
				<nav class="hidden lg:flex items-center gap-8">
					<a href={isEn ? "/en" : "/"} class={`nav-link text-[13px] font-semibold tracking-wide ${isActive(isEn ? "/en" : "/") || isActive(isEn ? "/en/" : "") ? "active" : ""}`}>
						{t.home}
					</a>
					
					<!-- Services Dropdown -->
					<div class="relative group">
						<button class={`nav-link flex items-center gap-1 text-[13px] font-semibold tracking-wide bg-transparent border-none outline-none cursor-pointer ${isServicesActive ? "active" : ""}`}>
							{t.services}
							<svg aria-hidden="true" class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<div class="absolute left-0 mt-2 w-56 rounded-xl bg-white border border-slate-200/80 shadow-lg p-2 opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-200 z-50 origin-top-left before:absolute before:-top-3 before:left-0 before:right-0 before:h-3 before:content-['']">
							<a href={isEn ? "/en/moving-services" : "/flyttjanster"} class="flex items-center px-4 py-2.5 rounded-lg text-[13px] font-medium text-slate-700 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcMoving}
							</a>
							<a href={isEn ? "/en/home-cleaning" : "/hemstadning"} class="flex items-center px-4 py-2.5 rounded-lg text-[13px] font-medium text-slate-700 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcCleaning}
							</a>
							<a href={isEn ? "/en/window-cleaning" : "/fonsterputsning"} class="flex items-center px-4 py-2.5 rounded-lg text-[13px] font-medium text-slate-700 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcWindows}
							</a>
							<a href={isEn ? "/en/roof-cleaning" : "/takrengoring"} class="flex items-center px-4 py-2.5 rounded-lg text-[13px] font-medium text-slate-700 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcRoof}
							</a>
							<a href={isEn ? "/en/gardening" : "/tradgardsvard"} class="flex items-center px-4 py-2.5 rounded-lg text-[13px] font-medium text-slate-700 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcGarden}
							</a>
						</div>
					</div>

					<a href={isEn ? "/en/about-us" : "/om-oss"} class={`nav-link text-[13px] font-semibold tracking-wide ${isActive(isEn ? "/en/about-us" : "/om-oss") ? "active" : ""}`}>
						{t.about}
					</a>
					<a href={isEn ? "/en/truck-rental" : "/lastbilsuthyrning"} class={`nav-link text-[13px] font-semibold tracking-wide ${isActive(isEn ? "/en/truck-rental" : "/lastbilsuthyrning") ? "active" : ""}`}>
						{t.truckRental}
					</a>
					<a href={isEn ? "/en/careers" : "/jobba-hos-oss"} class={`nav-link text-[13px] font-semibold tracking-wide ${isActive(isEn ? "/en/careers" : "/jobba-hos-oss") ? "active" : ""}`}>
						{t.careers}
					</a>

					<div class="w-px h-5 bg-slate-200"></div>

					<!-- Language toggle -->
					<a href={switchUrl} class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-slate-200 bg-white/80 hover:bg-white text-[11px] font-bold text-slate-700 transition-all shadow-xs active:scale-95" aria-label="Switch Language">
						{isEn ? (
							<!-- Swedish Flag SVG -->
							<svg aria-hidden="true" class="w-4.5 h-4.5 rounded-full overflow-hidden border border-slate-100/60 flex-shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<rect width="24" height="24" fill="#0052b4" />
								<rect x="7" width="3" height="24" fill="#ffda44" />
								<rect y="10.5" width="24" height="3" fill="#ffda44" />
							</svg>
							<span>SV</span>
						) : (
							<!-- UK Flag SVG -->
							<svg aria-hidden="true" class="w-4.5 h-4.5 rounded-full overflow-hidden border border-slate-100/60 flex-shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<rect width="24" height="24" fill="#00247d" />
								<path d="M0 0l24 24M0 24l24-24" stroke="#fff" stroke-width="2.5" />
								<path d="M0 0l24 24M0 24l24-24" stroke="#cf142b" stroke-width="1.2" />
								<rect x="9.5" width="5" height="24" fill="#fff" />
								<rect y="9.5" width="24" height="5" fill="#fff" />
								<rect x="10.5" width="3" height="24" fill="#cf142b" />
								<rect y="10.5" width="24" height="3" fill="#cf142b" />
							</svg>
							<span>EN</span>
						)}
					</a>

					<!-- CTA Button -->
					<a href={isEn ? "/en/contact" : "/contact"} class="ml-2 inline-flex items-center gap-2 text-[13px] font-bold px-5 py-2.5 rounded-lg bg-accent text-white hover:bg-accent-hover transition-colors shadow-sm active:scale-[0.98]">
						{t.contactUs}
						<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
					</a>
				</nav>

				<!-- Mobile Action Group -->
				<div class="lg:hidden flex items-center gap-3">
					<!-- Mobile Language Switcher -->
					<a href={switchUrl} class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-slate-200 bg-white/80 hover:bg-white text-[11px] font-bold text-slate-700 transition-all shadow-xs active:scale-95" aria-label="Switch Language">
						{isEn ? (
							<!-- Swedish Flag SVG -->
							<svg aria-hidden="true" class="w-4.5 h-4.5 rounded-full overflow-hidden border border-slate-100/60 flex-shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<rect width="24" height="24" fill="#0052b4" />
								<rect x="7" width="3" height="24" fill="#ffda44" />
								<rect y="10.5" width="24" height="3" fill="#ffda44" />
							</svg>
							<span>SV</span>
						) : (
							<!-- UK Flag SVG -->
							<svg aria-hidden="true" class="w-4.5 h-4.5 rounded-full overflow-hidden border border-slate-100/60 flex-shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<rect width="24" height="24" fill="#00247d" />
								<path d="M0 0l24 24M0 24l24-24" stroke="#fff" stroke-width="2.5" />
								<path d="M0 0l24 24M0 24l24-24" stroke="#cf142b" stroke-width="1.2" />
								<rect x="9.5" width="5" height="24" fill="#fff" />
								<rect y="9.5" width="24" height="5" fill="#fff" />
								<rect x="10.5" width="3" height="24" fill="#cf142b" />
								<rect y="10.5" width="24" height="3" fill="#cf142b" />
							</svg>
							<span>EN</span>
						)}
					</a>

					<!-- Mobile toggle -->
					<button id="menu-toggle" class="p-2 rounded-lg text-slate-600 hover:text-text-heading hover:bg-slate-100/50 transition-all outline-none" aria-label="Menu">
						<svg aria-hidden="true" id="menu-svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</button>
				</div>
			</div>

			<!-- Mobile nav -->
			<div id="mobile-menu" class="hidden lg:hidden border-t border-slate-100 bg-white shadow-lg absolute top-full left-0 right-0">
				<div class="max-w-6xl mx-auto px-6 py-5 flex flex-col gap-1">
					<a href={isEn ? "/en" : "/"} class={`text-[15px] font-semibold p-3 rounded-lg transition-colors ${isActive(isEn ? "/en" : "/") || isActive(isEn ? "/en/" : "") ? "bg-accent-soft text-accent" : "text-slate-700 hover:bg-slate-50"}`}>
						{t.home}
					</a>
					
					<!-- Mobile Services Dropdown Accordion -->
					<div class="flex flex-col">
						<button id="mobile-services-btn" class={`w-full flex items-center justify-between text-[15px] font-semibold p-3 rounded-lg text-slate-700 hover:bg-slate-50 transition-colors outline-none cursor-pointer ${isServicesActive ? "bg-accent-soft/40 text-accent" : ""}`}>
							<span>{t.services}</span>
							<svg aria-hidden="true" id="mobile-services-icon" class="w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<div id="mobile-services-menu" class="hidden flex-col pl-4 gap-0.5 border-l border-slate-100 ml-5 mt-1 mb-2">
							<a href={isEn ? "/en/moving-services" : "/flyttjanster"} class="text-sm font-medium p-2 rounded-lg text-slate-600 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcMoving}
							</a>
							<a href={isEn ? "/en/home-cleaning" : "/hemstadning"} class="text-sm font-medium p-2 rounded-lg text-slate-600 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcCleaning}
							</a>
							<a href={isEn ? "/en/window-cleaning" : "/fonsterputsning"} class="text-sm font-medium p-2 rounded-lg text-slate-600 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcWindows}
							</a>
							<a href={isEn ? "/en/roof-cleaning" : "/takrengoring"} class="text-sm font-medium p-2 rounded-lg text-slate-600 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcRoof}
							</a>
							<a href={isEn ? "/en/gardening" : "/tradgardsvard"} class="text-sm font-medium p-2 rounded-lg text-slate-600 hover:bg-slate-50 hover:text-accent transition-colors">
								{t.svcGarden}
							</a>
						</div>
					</div>

					<a href={isEn ? "/en/about-us" : "/om-oss"} class={`text-[15px] font-semibold p-3 rounded-lg transition-colors ${isActive(isEn ? "/en/about-us" : "/om-oss") ? "bg-accent-soft text-accent" : "text-slate-700 hover:bg-slate-50"}`}>
						{t.about}
					</a>
					<a href={isEn ? "/en/truck-rental" : "/lastbilsuthyrning"} class={`text-[15px] font-semibold p-3 rounded-lg transition-colors ${isActive(isEn ? "/en/truck-rental" : "/lastbilsuthyrning") ? "bg-accent-soft text-accent" : "text-slate-700 hover:bg-slate-50"}`}>
						{t.truckRental}
					</a>
					<a href={isEn ? "/en/careers" : "/jobba-hos-oss"} class={`text-[15px] font-semibold p-3 rounded-lg transition-colors ${isActive(isEn ? "/en/careers" : "/jobba-hos-oss") ? "bg-accent-soft text-accent" : "text-slate-700 hover:bg-slate-50"}`}>
						{t.careers}
					</a>



					<a href={isEn ? "/en/contact" : "/contact"} class="mt-3 flex items-center justify-center gap-2 py-3.5 rounded-lg bg-accent text-white text-sm font-bold hover:bg-accent-hover transition-colors">
						{t.contactUs}
					</a>
				</div>
			</div>
		</header>

		<!-- Page content -->
		<div class="flex-grow w-full pt-[72px] page-fade-in">
			<slot />
		</div>

		<!-- ═══ FOOTER (High Contrast Dark Navy) ═══ -->
		<footer class="w-full bg-[#020617] text-slate-400 border-t border-slate-900 relative">
			<!-- Top accent gradient divider line -->
			<div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/50 to-transparent"></div>
			
			<div class="max-w-6xl mx-auto px-6 py-16">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

					<!-- Col 1: Brand -->
					<div class="md:col-span-2 lg:col-span-1">
						<div class="flex items-center gap-3 mb-5">
							<img src="/mi-logo.png" alt="" aria-hidden="true" class="h-10 w-auto object-contain brightness-0 invert" width="133" height="40" loading="lazy" />
							<span class="text-base font-bold text-white tracking-tight">Sonvice Group</span>
						</div>
						<p class="text-sm text-slate-400 leading-relaxed max-w-xs">
							{t.footerDesc}
						</p>
					</div>

					<!-- Col 2: Services -->
					<div>
						<h3 class="text-[11px] font-extrabold text-white uppercase tracking-[0.2em] mb-5">{t.footerServices}</h3>
						<ul class="space-y-3.5 text-sm">
							<li><a href={isEn ? "/en/moving-services" : "/flyttjanster"} class="text-slate-400 hover:text-accent font-medium transition-colors">{t.svcMoving}</a></li>
							<li><a href={isEn ? "/en/home-cleaning" : "/hemstadning"} class="text-slate-400 hover:text-accent font-medium transition-colors">{t.svcCleaning}</a></li>
							<li><a href={isEn ? "/en/window-cleaning" : "/fonsterputsning"} class="text-slate-400 hover:text-accent font-medium transition-colors">{t.svcWindows}</a></li>
							<li><a href={isEn ? "/en/roof-cleaning" : "/takrengoring"} class="text-slate-400 hover:text-accent font-medium transition-colors">{t.svcRoof}</a></li>
							<li><a href={isEn ? "/en/gardening" : "/tradgardsvard"} class="text-slate-400 hover:text-accent font-medium transition-colors">{t.svcGarden}</a></li>
							<li><a href={isEn ? "/en/truck-rental" : "/lastbilsuthyrning"} class="text-slate-400 hover:text-accent font-medium transition-colors">{t.svcTruck}</a></li>
						</ul>
					</div>

					<!-- Col 3: Company -->
					<div>
						<h3 class="text-[11px] font-extrabold text-white uppercase tracking-[0.2em] mb-5">{t.footerCompany}</h3>
						<ul class="space-y-3.5 text-sm">
							<li><a href={isEn ? "/en/about-us" : "/om-oss"} class="text-slate-400 hover:text-accent font-medium transition-colors">{t.about}</a></li>
