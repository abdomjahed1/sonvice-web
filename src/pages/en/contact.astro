---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Contact us | Sonvice Group" description="Fill in our contact form to request a free quote for moving, cleaning, or other household services in Kronoberg/Kalmar. Fast response!">
<main class="bg-surface-body py-12 md:py-24 bg-grid-pattern relative">
	<!-- Ambient lights -->
	<div class="absolute top-[20%] left-[10%] w-[350px] h-[350px] bg-glow-teal rounded-full blur-[80px] -z-10 pointer-events-none"></div>
	<div class="absolute bottom-[20%] right-[10%] w-[300px] h-[300px] bg-glow-amber rounded-full blur-[70px] -z-10 pointer-events-none"></div>

	<div class="max-w-6xl mx-auto px-6 relative">
		
		<!-- Split-screen glowing container card -->
		<div class="glow-card grid grid-cols-1 lg:grid-cols-5 gap-0 rounded-2xl overflow-hidden border border-slate-200/80 shadow-md bg-white">
			
			<!-- Left: Dark Info Panel (col-span-2) -->
			<div class="lg:col-span-2 bg-surface-dark p-8 md:p-12 text-white flex flex-col justify-between relative overflow-hidden">
				<div class="absolute -right-16 -top-16 w-36 h-36 bg-glow-teal rounded-full blur-2xl opacity-20 pointer-events-none"></div>
				
				<div class="relative z-10 space-y-10">
					<div>
						<span class="text-xs font-bold text-accent uppercase tracking-widest bg-teal-900/40 border border-teal-800/60 px-2.5 py-1 rounded">Contact</span>
						<h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mt-4 mb-4">Contact us</h1>
						<p class="text-slate-400 text-sm md:text-base leading-relaxed">Fill in the form to request a free quote. We normally respond within 24 hours.</p>
					</div>
					
					<!-- Contact details -->
					<div class="space-y-6">
						<div class="flex items-start gap-4 group">
							<div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-800 flex items-center justify-center flex-shrink-0 group-hover:border-accent transition-colors duration-300">
								<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
							</div>
							<div>
								<div class="text-[10px] text-slate-500 font-bold uppercase tracking-wider mb-0.5">Email</div>
								<a href="mailto:info@sonvicegroup.se" class="text-sm font-semibold text-white hover:text-accent transition-colors">info@sonvicegroup.se</a>
							</div>
						</div>
						
						<div class="flex items-start gap-4 group">
							<div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-800 flex items-center justify-center flex-shrink-0 group-hover:border-accent transition-colors duration-300">
								<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
							</div>
							<div>
								<div class="text-[10px] text-slate-500 font-bold uppercase tracking-wider mb-0.5">Phone</div>
								<a href="tel:081234567" class="text-sm font-semibold text-white hover:text-accent transition-colors">08-123 45 67</a>
							</div>
						</div>
						
						<div class="flex items-start gap-4 group">
							<div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-800 flex items-center justify-center flex-shrink-0 group-hover:border-accent transition-colors duration-300">
								<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							</div>
							<div>
								<div class="text-[10px] text-slate-500 font-bold uppercase tracking-wider mb-0.5">Hours</div>
								<div class="text-sm text-slate-300">Mon–Fri 08–18 · Sat 09–15</div>
								<div class="text-xs text-slate-500 mt-1">Sunday: Closed (On-call support available)</div>
							</div>
						</div>
					</div>
				</div>
				
				<!-- Tip Box -->
				<div class="relative z-10 mt-12 p-5 rounded-lg bg-surface-dark-raised border border-slate-800/80 text-sm text-slate-400 leading-relaxed">
					<strong class="text-slate-200">Tip:</strong> Please specify the area (sqm), number of rooms, and preferred date in your message to help us give you a more accurate quote directly.
				</div>
			</div>
			
			<!-- Right: Form Panel (col-span-3) -->
			<div class="lg:col-span-3 bg-white p-8 md:p-12 relative flex flex-col justify-center">
				
				<!-- Price Summary Card (Dynamically updated) -->
				<div id="price-summary-container" class="hidden p-5 rounded-2xl bg-slate-900 border border-slate-800 text-white relative overflow-hidden mb-6 shadow-md transition-all duration-300">
					<div class="absolute inset-0 bg-gradient-to-r from-teal-500/10 to-emerald-500/10 pointer-events-none"></div>
					<div class="relative z-10">
						<span class="text-[10px] font-bold text-teal-400 uppercase tracking-wider block mb-1">Price Estimate</span>
						<div class="text-2xl font-extrabold text-white">
							ca <span id="summary-price" class="font-mono">0</span> kr
						</div>
						<p id="summary-details" class="text-xs text-slate-400 mt-1 leading-normal">Estimated price based on your settings.</p>
						<div id="summary-saving-note" class="text-[11px] text-teal-300 font-semibold mt-1.5 hidden"></div>
					</div>
				</div>

				<div id="form-container" class="transition-all duration-300">
					<form id="contact-form" class="space-y-6">
						<!-- Web3Forms Integration -->
						<input type="hidden" name="access_key" value="d23d6104-1a1b-4ffd-a91a-87cfeff7192f" />
						<input type="hidden" name="subject" value="[Web Contact] New quote request from sonvicegroup.se" />
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label for="name" class="text-sm font-semibold text-slate-700 mb-2 block">Full Name *</label>
								<input 
									type="text" 
									id="name" 
									name="name"
									required 
									placeholder="Your name" 
									class="w-full px-4 py-3.5 rounded-lg bg-slate-50/50 border border-slate-200 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:bg-white outline-none transition-all duration-300 text-sm text-text-heading placeholder-slate-400 shadow-inner-xs" 
								/>
							</div>
							
							<div>
								<label for="email" class="text-sm font-semibold text-slate-700 mb-2 block">Email Address *</label>
								<input 
									type="email" 
									id="email" 
									name="email"
									required 
									placeholder="name@example.com" 
									class="w-full px-4 py-3.5 rounded-lg bg-slate-50/50 border border-slate-200 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:bg-white outline-none transition-all duration-300 text-sm text-text-heading placeholder-slate-400 shadow-inner-xs" 
								/>
							</div>
						</div>
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label for="phone" class="text-sm font-semibold text-slate-700 mb-2 block">Phone Number</label>
								<input 
									type="tel" 
									id="phone" 
									name="phone"
									placeholder="070-123 45 67" 
									class="w-full px-4 py-3.5 rounded-lg bg-slate-50/50 border border-slate-200 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:bg-white outline-none transition-all duration-300 text-sm text-text-heading placeholder-slate-400 shadow-inner-xs" 
								/>
							</div>
							
							<div>
								<label for="service" class="text-sm font-semibold text-slate-700 mb-2 block">Requested Service *</label>
								<select 
									id="service" 
									name="service"
									required 
									class="w-full px-4 py-3.5 rounded-lg bg-slate-50/50 border border-slate-200 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:bg-white outline-none transition-all duration-300 text-sm text-text-heading placeholder-slate-400 cursor-pointer shadow-inner-xs"
								>
									<option value="" disabled selected>Select a service...</option>
									<option value="flytt">Moving Services</option>
									<option value="hemstadning">Home Cleaning</option>
									<option value="fonsterputs">Window Cleaning</option>
									<option value="takrengoring">Roof Cleaning</option>
									<option value="tradgard">Gardening Services</option>
									<option value="lastbil">Truck Rental</option>
									<option value="annat">Other / General Inquiry</option>
								</select>
							</div>
						</div>

						<!-- Dynamic size container (Conditional) -->
						<div id="size-container" class="hidden transition-all duration-300">
							<label for="size-input" id="size-label" class="text-sm font-semibold text-slate-700 mb-2 block">Property Size (sqm) *</label>
							<input 
								type="number" 
								id="size-input" 
								name="size"
								min="1" 
								max="999"
								placeholder="e.g. 65" 
								class="w-full px-4 py-3.5 rounded-lg bg-slate-50/50 border border-slate-200 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:bg-white outline-none transition-all duration-300 text-sm text-text-heading placeholder-slate-400 shadow-inner-xs" 
							/>
						</div>

						<!-- Rent Truck package select (Conditional) -->
						<div id="truck-package-container" class="hidden transition-all duration-300">
							<label for="truck-package" class="text-sm font-semibold text-slate-700 mb-2 block">Select Rental Period *</label>
							<select 
								id="truck-package" 
								name="truck_package"
								class="w-full px-4 py-3.5 rounded-lg bg-slate-50/50 border border-slate-200 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:bg-white outline-none transition-all duration-300 text-sm text-text-heading placeholder-slate-400 cursor-pointer shadow-inner-xs"
							>
								<option value="" disabled selected>Select package...</option>
								<option value="1_day">1 day (1,000 SEK) — Incl. 130 km</option>
								<option value="3_days">3 days (2,100 SEK) — Incl. free mileage up to 390 km</option>
								<option value="7_days">7 days (4,500 SEK) — Weekly, incl. free mileage up to 910 km</option>
								<option value="other">Other / Custom period (specify in details below)</option>
							</select>
						</div>
						
						<div>
							<label for="message" class="text-sm font-semibold text-slate-700 mb-2 block">Description of the service *</label>
							<textarea 
								id="message" 
								name="message"
								rows="4" 
								required 
								placeholder="Describe preferred date, number of rooms, or other details." 
								class="w-full px-4 py-3.5 rounded-lg bg-slate-50/50 border border-slate-200 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:bg-white outline-none transition-all duration-300 resize-none text-sm text-text-heading placeholder-slate-400 shadow-inner-xs"
							></textarea>
						</div>

						<!-- Honeypot Bot Protection (invisible to users) -->
						<div class="hidden" aria-hidden="true" style="display: none;">
							<label for="honeypot">Leave this field blank / Lämna detta fält tomt</label>
							<input type="text" id="honeypot" name="honeypot" tabindex="-1" autocomplete="off" />
						</div>
						
						<button 
							type="submit" 
							id="submit-btn"
							class="group relative overflow-hidden w-full py-4 rounded-lg bg-gradient-to-r from-teal-600 to-emerald-600 hover:from-teal-500 hover:to-emerald-500 text-white font-bold text-sm transition-all flex items-center justify-center gap-2 cursor-pointer shadow-md shadow-teal-500/10 active:scale-[0.98]"
						>
							<span class="shimmer-effect"></span>
							<span id="btn-text" class="relative z-10">Send Enquiry</span>
							<svg id="btn-icon" class="w-4 h-4 relative z-10 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
							<svg id="btn-spinner" class="w-5 h-5 animate-spin hidden relative z-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
						</button>
					</form>
				</div>

				<!-- Success State Panel -->
				<div id="success-container" class="hidden text-center py-8 space-y-6">
					<div class="mx-auto w-16 h-16 bg-teal-50 border border-teal-100 rounded-full flex items-center justify-center text-teal-600 shadow-xs animate-scale-up">
						<svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="20 6 9 17 4 12" class="animate-draw-check"></polyline>
						</svg>
					</div>

					<div class="space-y-2">
						<h2 class="text-2xl font-bold text-text-heading">Enquiry Received!</h2>
						<p class="text-sm text-text-body leading-relaxed max-w-sm mx-auto">
							Thank you <span id="success-client-name" class="font-semibold text-slate-800"></span>. We have received your request and a confirmation has been sent to <span id="success-client-email" class="font-semibold text-slate-800"></span>.
						</p>
					</div>

					<!-- Receipt Card -->
					<div class="bg-slate-50 border border-slate-200/80 rounded-xl p-5 text-left text-xs max-w-sm mx-auto space-y-2">
						<div class="flex justify-between border-b border-slate-100 pb-2">
							<span class="text-slate-400 font-semibold uppercase tracking-wider">Service</span>
							<span id="receipt-service" class="font-bold text-slate-700"></span>
						</div>
						<div id="receipt-size-row" class="flex justify-between border-b border-slate-100 pb-2 hidden">
							<span class="text-slate-400 font-semibold uppercase tracking-wider">Size</span>
							<span id="receipt-size" class="font-bold text-slate-700"></span>
						</div>
						<div id="receipt-package-row" class="flex justify-between border-b border-slate-100 pb-2 hidden">
							<span class="text-slate-400 font-semibold uppercase tracking-wider">Rental Period</span>
							<span id="receipt-package" class="font-bold text-slate-700"></span>
						</div>
						<div id="receipt-price-row" class="flex justify-between border-b border-slate-100 pb-2 hidden">
							<span class="text-slate-400 font-semibold uppercase tracking-wider">Estimate</span>
							<span id="receipt-price" class="font-bold text-teal-600"></span>
						</div>
						<div class="flex justify-between pt-1">
							<span class="text-slate-400 font-semibold uppercase tracking-wider">Phone</span>
							<span id="receipt-phone" class="font-bold text-slate-700"></span>
						</div>
					</div>

					<p class="text-xs text-text-muted max-w-xs mx-auto">
						A representative will review the details and get back to you with a formal quote within 24 hours.
					</p>

					<div class="pt-4">
						<a href="/en" class="inline-flex items-center justify-center px-6 py-2.5 rounded-lg border border-slate-200 hover:bg-slate-50 text-xs font-bold text-slate-700 transition-colors cursor-pointer">
							Back to homepage
						</a>
					</div>
				</div>

			</div>
			
		</div>
		
	</div>
</main>

<style>
	@keyframes drawCheck {
		to { stroke-dashoffset: 0; }
	}
	@keyframes scaleUp {
		from { transform: scale(0.8); opacity: 0; }
		to { transform: scale(1); opacity: 1; }
	}
	@keyframes shimmer {
		100% { transform: translateX(100%) skewX(-12deg); }
	}
	.animate-scale-up {
		animation: scaleUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}
	.animate-draw-check {
		stroke-dasharray: 24;
		stroke-dashoffset: 24;
		animation: drawCheck 0.5s ease-out 0.2s forwards;
	}
	.shimmer-effect {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(
			90deg,
			rgba(255, 255, 255, 0) 0%,
			rgba(255, 255, 255, 0.2) 20%,
			rgba(255, 255, 255, 0.6) 60%,
			rgba(255, 255, 255, 0) 100%
		);
		transform: translateX(-100%) skewX(-12deg);
		transition: none;
	}
	.group:hover .shimmer-effect {
		animation: shimmer 1.2s ease-in-out infinite;
	}
	/* Shadow styles for inputs */
	.shadow-inner-xs {
		box-shadow: inset 0 1px 2px 0 rgba(0, 0, 0, 0.05);
	}
</style>

<!-- Mouse Spotlight Follow script initialization -->
<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (window.initGlowCards) {
			window.initGlowCards();
		}

		const serviceSelect = document.getElementById('service');
		const sizeContainer = document.getElementById('size-container');
		const sizeLabel = document.getElementById('size-label');
		const sizeInput = document.getElementById('size-input');
		const truckContainer = document.getElementById('truck-package-container');
		const truckPackageSelect = document.getElementById('truck-package');
		
		const priceSummaryContainer = document.getElementById('price-summary-container');
		const summaryPrice = document.getElementById('summary-price');
		const summaryDetails = document.getElementById('summary-details');
		const summarySavingNote = document.getElementById('summary-saving-note');

		const updatePriceSummary = () => {
			if (!serviceSelect || !sizeInput) return;
			const service = serviceSelect.value;
			const size = parseInt(sizeInput.value, 10);
			
			if (!service || isNaN(size) || size <= 0) {
				if (priceSummaryContainer) priceSummaryContainer.classList.add('hidden');
				return;
			}

			let finalPrice = 0;
			let savings = 0;
			let isRut = false;
			let isRot = false;
			let showSummary = false;
			let detailsText = "";
			let savingsText = "";

			if (service === 'flytt') {
				finalPrice = 1500 + (size * 120);
				detailsText = `Based on ${size} m³ volume for moving services (incl. VAT and insurance).`;
				showSummary = true;
			} else if (service === 'hemstadning') {
				const base = 600 + (size * 30);
				finalPrice = base * 0.5;
				savings = base * 0.5;
				isRut = true;
				detailsText = `Based on ${size} m² cleaning area (incl. VAT and materials).`;
				savingsText = `Your price after RUT tax credit (you save ca ${Math.round(savings).toLocaleString('sv-SE')} kr)`;
				showSummary = true;
			} else if (service === 'takrengoring') {
				let base = size * 56;
				let minApplied = false;
				if (base < 4500) {
					base = 4500;
					minApplied = true;
				}
				finalPrice = base * 0.7;
				savings = base * 0.3;
				isRot = true;
				detailsText = `Based on ${size} m² roof area (incl. VAT).${minApplied ? ' Minimum charge of 4 500 kr (before ROT) applied.' : ''}`;
				savingsText = `Your price after ROT tax credit (you save ca ${Math.round(savings).toLocaleString('sv-SE')} kr)`;
				showSummary = true;
			} else {
				showSummary = false;
			}

			if (showSummary && priceSummaryContainer) {
				priceSummaryContainer.classList.remove('hidden');
				if (summaryPrice) summaryPrice.textContent = Math.round(finalPrice).toLocaleString('sv-SE');
				if (summaryDetails) summaryDetails.textContent = detailsText;
				if (summarySavingNote) {
					if (isRut || isRot) {
						summarySavingNote.classList.remove('hidden');
						summarySavingNote.innerHTML = savingsText;
					} else {
						summarySavingNote.classList.add('hidden');
					}
				}
			} else {
				if (priceSummaryContainer) priceSummaryContainer.classList.add('hidden');
			}
		};

		const checkService = () => {
			if (!serviceSelect) return;
			const service = serviceSelect.value;
			
			// Handle truck rental selection
			if (service === 'lastbil' || service === 'truck') {
				if (truckContainer) truckContainer.classList.remove('hidden');
				if (truckPackageSelect) truckPackageSelect.setAttribute('required', 'true');
			} else {
				if (truckContainer) truckContainer.classList.add('hidden');
				if (truckPackageSelect) {
					truckPackageSelect.removeAttribute('required');
					truckPackageSelect.value = "";
				}
			}

			// Handle sizing field selection (flytt, hemstadning, takrengoring)
			if (service === 'flytt' || service === 'hemstadning' || service === 'takrengoring') {
				if (sizeContainer) {
					sizeContainer.classList.remove('hidden');
					if (sizeInput) sizeInput.setAttribute('required', 'true');
					
					if (service === 'takrengoring') {
						if (sizeLabel) sizeLabel.innerHTML = 'Roof size (square meters) *';
						if (sizeInput) sizeInput.placeholder = 'e.g. 120';
					} else if (service === 'flytt') {
						if (sizeLabel) sizeLabel.innerHTML = 'Volume (cubic meters) * <span class="text-[11px] text-slate-400 font-normal block mt-1">If unsure, estimate ca 10–15 cubic meters (m³) per room (e.g. 3 rooms = ca 30–45 m³).</span>';
						if (sizeInput) sizeInput.placeholder = 'e.g. 30';
					} else {
						if (sizeLabel) sizeLabel.innerHTML = 'Property size (square meters) *';
						if (sizeInput) sizeInput.placeholder = 'e.g. 65';
					}
				}
			} else {
				if (sizeContainer) {
					sizeContainer.classList.add('hidden');
					if (sizeInput) {
						sizeInput.removeAttribute('required');
						sizeInput.value = "";
					}
				}
			}
			updatePriceSummary();
		};

		if (serviceSelect) {
			serviceSelect.addEventListener('change', checkService);
			if (sizeInput) {
				sizeInput.addEventListener('input', updatePriceSummary);
			}

			// Read URL parameters on load to auto-select
			const urlParams = new URLSearchParams(window.location.search);
			const serviceParam = urlParams.get('service');
			const sizeParam = urlParams.get('size');
			const packageParam = urlParams.get('package');

			if (serviceParam) {
				if (serviceParam === 'lastbil' || serviceParam === 'truck') {
					serviceSelect.value = 'lastbil';
				} else if (serviceParam === 'moving' || serviceParam === 'flytt') {
					serviceSelect.value = 'flytt';
				} else if (serviceParam === 'cleaning' || serviceParam === 'hemstadning') {
					serviceSelect.value = 'hemstadning';
				} else if (serviceParam === 'roof' || serviceParam === 'takrengoring') {
					serviceSelect.value = 'takrengoring';
				} else {
					serviceSelect.value = serviceParam;
				}
			}

			checkService();

			if (sizeParam && sizeInput && (serviceSelect.value === 'flytt' || serviceSelect.value === 'hemstadning' || serviceSelect.value === 'takrengoring')) {
				sizeInput.value = sizeParam;
				updatePriceSummary();
			}

			if (packageParam && truckPackageSelect) {
				truckPackageSelect.value = packageParam;
			}
		}

		// Handle Form Submit Success Animation State
		const contactForm = document.getElementById('contact-form');
		const formContainer = document.getElementById('form-container');
		const successContainer = document.getElementById('success-container');
		const submitBtn = document.getElementById('submit-btn');
		const btnText = document.getElementById('btn-text');
		const btnIcon = document.getElementById('btn-icon');
		const btnSpinner = document.getElementById('btn-spinner');

		// Success elements
		const successClientName = document.getElementById('success-client-name');
		const successClientEmail = document.getElementById('success-client-email');
		const receiptService = document.getElementById('receipt-service');
		const receiptSizeRow = document.getElementById('receipt-size-row');
		const receiptSize = document.getElementById('receipt-size');
		const receiptPackageRow = document.getElementById('receipt-package-row');
		const receiptPackage = document.getElementById('receipt-package');
		const receiptPriceRow = document.getElementById('receipt-price-row');
		const receiptPrice = document.getElementById('receipt-price');
		const receiptPhone = document.getElementById('receipt-phone');

		if (contactForm && formContainer && successContainer && submitBtn) {
			const pageLoadTime = Date.now();

			contactForm.addEventListener('submit', (e) => {
				e.preventDefault();

				// 1. Honeypot check (bots fill in all inputs)
				const honeyVal = document.getElementById('honeypot')?.value;
				if (honeyVal) {
					console.warn('Silent discard: bot submission detected (honeypot filled)');
					formContainer.classList.add('hidden');
					if (priceSummaryContainer) priceSummaryContainer.classList.add('hidden');
					successContainer.classList.remove('hidden');
					return;
				}

				// 2. Time-trap check (bots submit instantaneously, e.g. < 1.5 seconds)
				const submitTime = Date.now();
				if (submitTime - pageLoadTime < 1500) {
					console.warn('Silent discard: bot submission detected (instant submit)');
					formContainer.classList.add('hidden');
					if (priceSummaryContainer) priceSummaryContainer.classList.add('hidden');
					successContainer.classList.remove('hidden');
					return;
				}

				// Loading state
				submitBtn.setAttribute('disabled', 'true');
				submitBtn.classList.add('opacity-80', 'cursor-not-allowed');
				if (btnText) btnText.textContent = 'Sending...';
				if (btnIcon) btnIcon.classList.add('hidden');
				if (btnSpinner) btnSpinner.classList.remove('hidden');

				// Gather data
				const nameVal = document.getElementById('name').value;
				const emailVal = document.getElementById('email').value;
				const phoneVal = document.getElementById('phone').value || 'Not provided';
				const serviceVal = serviceSelect.options[serviceSelect.selectedIndex].text;
				const sizeVal = sizeInput ? sizeInput.value : '';
				const packageVal = truckPackageSelect && !truckPackageSelect.parentElement.classList.contains('hidden') && truckPackageSelect.value ? truckPackageSelect.options[truckPackageSelect.selectedIndex].text : '';

				// Populate success content
				if (successClientName) successClientName.textContent = nameVal;
				if (successClientEmail) successClientEmail.textContent = emailVal;
				if (receiptService) receiptService.textContent = serviceVal;
				if (receiptPhone) receiptPhone.textContent = phoneVal;

				if (sizeVal && sizeContainer && !sizeContainer.classList.contains('hidden')) {
					const unit = serviceSelect.value === 'flytt' ? 'm³' : 'm²';
					if (receiptSize) receiptSize.textContent = `${sizeVal} ${unit}`;
					if (receiptSizeRow) receiptSizeRow.classList.remove('hidden');
				} else {
					if (receiptSizeRow) receiptSizeRow.classList.add('hidden');
				}

				if (packageVal) {
					if (receiptPackage) receiptPackage.textContent = packageVal;
					if (receiptPackageRow) receiptPackageRow.classList.remove('hidden');
				} else {
					if (receiptPackageRow) receiptPackageRow.classList.add('hidden');
				}

				// Price estimation receipt
				if (priceSummaryContainer && !priceSummaryContainer.classList.contains('hidden') && summaryPrice) {
					if (receiptPrice) receiptPrice.textContent = `ca ${summaryPrice.textContent} kr`;
					if (receiptPriceRow) receiptPriceRow.classList.remove('hidden');
				} else {
					if (receiptPriceRow) receiptPriceRow.classList.add('hidden');
				}

				// Construct form data for Web3Forms post
				const formData = new FormData(contactForm);
				
				// Append price estimation info to message so the email has the calculated price
				if (priceSummaryContainer && !priceSummaryContainer.classList.contains('hidden') && summaryPrice) {
					const estimationInfo = `\n\n--- Price Estimation on Website ---\nEstimated price: ca ${summaryPrice.textContent} kr\nDetails: ${summaryDetails.textContent}`;
					formData.set('message', formData.get('message') + estimationInfo);
				}

				// Submit to Web3Forms
				fetch('https://api.web3forms.com/submit', {
					method: 'POST',
					body: formData
				})
				.then(response => response.json())
				.then(data => {
					if (data.success) {
						// Transition to success state
						formContainer.classList.add('hidden');
						if (priceSummaryContainer) priceSummaryContainer.classList.add('hidden');
						successContainer.classList.remove('hidden');
						successContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
					} else {
						alert('Something went wrong during submission. Please try again or email us directly at info@sonvicegroup.se.');
						// Reset button state
						submitBtn.removeAttribute('disabled');
						submitBtn.classList.remove('opacity-80', 'cursor-not-allowed');
						if (btnText) btnText.textContent = 'Send Enquiry';
						if (btnIcon) btnIcon.classList.remove('hidden');
						if (btnSpinner) btnSpinner.classList.add('hidden');
					}
				})
				.catch(error => {
					console.error('Error submitting form:', error);
					alert('A network error occurred. Please check your connection and try again.');
					// Reset button state
					submitBtn.removeAttribute('disabled');
					submitBtn.classList.remove('opacity-80', 'cursor-not-allowed');
					if (btnText) btnText.textContent = 'Send Enquiry';
					if (btnIcon) btnIcon.classList.remove('hidden');
					if (btnSpinner) btnSpinner.classList.add('hidden');
				});
			});
		}
	});
</script>
</Layout>
