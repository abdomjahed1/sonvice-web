---
import Layout from '../../layouts/Layout.astro';
import hemstadningImg from '../../images/Hemstädning.jpg';
---

<Layout title="Home Cleaning Kronoberg/Kalmar | Subscription Cleaning | Sonvice Group" description="Professional home cleaning services in Kronoberg/Kalmar. Subscription or one-off packages, trained staff, 100% satisfaction guarantee, and RUT tax credit.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO ═══════════════════ -->
	<section class="relative bg-white pt-12 pb-20 md:py-28 bg-grid-pattern">
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] -z-10 pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[30%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] -z-10 pointer-events-none animate-float-delay"></div>

		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
				
				<div class="lg:col-span-7 space-y-7 reveal-on-scroll">
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Spotless Home, Effortless Service</span>
					</div>
					
					<h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight text-text-heading leading-[1.08]">
						Professional
						<span class="block bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">home cleaning in Kronoberg/Kalmar</span>
					</h1>
					
					<p class="text-lg text-text-body leading-relaxed max-w-xl">
						Sit back, relax, and let us do the work. We offer regular home cleaning (weekly, bi-weekly, or monthly) and one-off cleanings with trained staff, the same dedicated cleaner every time, and a 100% satisfaction guarantee.
					</p>

					<div class="flex flex-wrap items-center gap-4 pt-2">
						<a href="/en/contact?service=hemstadning" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm">
							Request a free quote
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Call 08-123 45 67
						</a>
					</div>

					<div class="flex flex-wrap items-center gap-x-6 gap-y-3 pt-5 border-t border-slate-100 text-sm text-slate-500">
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
							Trygg-Hansa liability insurance
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							100% Satisfaction Guarantee
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							No binding periods
						</span>
					</div>
				</div>

				<div class="lg:col-span-5 relative reveal-on-scroll delay-200">
					<div class="absolute -inset-4 border border-dashed border-slate-200/80 rounded-3xl -z-10 pointer-events-none"></div>
					<div class="tilt-card rounded-2xl overflow-hidden aspect-[4/3] bg-slate-50 border border-slate-200/60 shadow-md">
						<img src={hemstadningImg.src} alt="Professional home cleaning services" class="w-full h-full object-cover transition-transform duration-700 tilt-inner" />
					</div>
					<div class="absolute -bottom-6 -left-6 md:bottom-8 md:-left-8 glass-panel rounded-xl shadow-lg p-5 border border-slate-200/80 max-w-[200px]">
						<div class="text-2xl font-extrabold text-accent">fr. 195 kr</div>
						<div class="text-xs text-text-heading font-bold uppercase tracking-wider mt-1">per hour</div>
						<p class="text-[10px] text-text-muted mt-1 leading-normal">After RUT tax credit (incl. VAT & materials).</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ WHAT'S INCLUDED ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden border-t border-slate-100">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest font-mono">Checklist</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">What's included in home cleaning?</h2>
				<p class="text-text-body text-base">We clean every room meticulously. Here is our standard scope of work:</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal-on-scroll delay-100">
				<!-- All Rooms -->
				<div class="bg-white rounded-2xl p-7 shadow-xs border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
							<polyline points="9 22 9 12 15 12 15 22"></polyline>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">All Living Areas</h3>
					<ul class="space-y-3 text-xs text-text-body">
						<li class="flex gap-2">✓ <span>Dusting of all open surfaces, tables, shelves, and lamps.</span></li>
						<li class="flex gap-2">✓ <span>Vacuuming of floors, rugs, and underneath accessible furniture.</span></li>
						<li class="flex gap-2">✓ <span>Mopping of all hard floors with customized cleaning agents.</span></li>
						<li class="flex gap-2">✓ <span>Wiping of doors, frames, light switches, and power sockets.</span></li>
						<li class="flex gap-2">✓ <span>Emptying waste baskets.</span></li>
					</ul>
				</div>
				<!-- Kitchen -->
				<div class="bg-white rounded-2xl p-7 shadow-xs border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="10" cy="14" r="6"></circle>
							<line x1="14.2" y1="9.8" x2="21" y2="3"></line>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Kitchen</h3>
					<ul class="space-y-3 text-xs text-text-body">
						<li class="flex gap-2">✓ <span>Cleaning sink, faucets, and backsplash tiles.</span></li>
						<li class="flex gap-2">✓ <span>Wiping exterior of stove, oven, microwave, fridge, and freezer.</span></li>
						<li class="flex gap-2">✓ <span>Wiping cabinet doors and drawer fronts.</span></li>
						<li class="flex gap-2">✓ <span>Wiping exterior of range hood and cleaning grease filters.</span></li>
						<li class="flex gap-2">✓ <span>Wiping countertops, kitchen appliances, and dining table.</span></li>
					</ul>
				</div>
				<!-- Bathroom -->
				<div class="bg-white rounded-2xl p-7 shadow-xs border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Bathroom & Toilet</h3>
					<ul class="space-y-3 text-xs text-text-body">
						<li class="flex gap-2">✓ <span>Sanitizing toilet bowl and washbasin.</span></li>
						<li class="flex gap-2">✓ <span>Cleaning shower cabin, bathtub, mixers, and glass screens.</span></li>
						<li class="flex gap-2">✓ <span>Wiping tiles and mirrors.</span></li>
						<li class="flex gap-2">✓ <span>Wiping cabinet fronts.</span></li>
						<li class="flex gap-2">✓ <span>Wiping exterior of washing machine and tumble dryer.</span></li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ RUT TAX CREDIT ═══════════════════ -->
	<section class="py-20 bg-surface-warm relative border-t border-slate-100">
		<div class="absolute bottom-0 left-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>
		<div class="max-w-5xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 space-y-6 reveal-on-scroll">
					<span class="text-xs font-bold text-accent uppercase tracking-widest">RUT Credit</span>
					<h2 class="text-3xl font-bold text-text-heading tracking-tight">Home cleaning at half the price</h2>
					<p class="text-sm text-text-body leading-relaxed">
						The Swedish RUT tax deduction gives you a <strong>50% skatterabatt</strong> on the labor cost for home cleaning services. This means you only pay half of the cleaning labor rate. Skatteverket allows deductions up to 75,000 SEK per person per year.
					</p>
					<div class="space-y-3 text-xs text-text-body">
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>We deduct the RUT credit directly on every monthly invoice.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>We manage all the tax applications with Skatteverket on your behalf.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>No binding period – pause or cancel your subscription whenever you wish.</span>
						</div>
					</div>
				</div>
				<div class="lg:col-span-6 reveal-on-scroll delay-200">
					<div class="bg-white rounded-2xl p-8 border border-slate-200/80 shadow-xs space-y-4">
						<h3 class="font-bold text-text-heading text-lg">Subscription Example</h3>
						<div class="space-y-2 text-xs border-b border-slate-100 pb-4">
							<div class="flex justify-between">
								<span>Bi-weekly cleaning (4 hours per visit = 8 hours/month)</span>
								<span class="font-mono">3,120 SEK</span>
							</div>
							<div class="flex justify-between text-slate-400">
								<span>Cleaning materials and environmental fee (Included)</span>
								<span class="font-mono">0 SEK</span>
							</div>
						</div>
						<div class="space-y-2 text-xs pt-2">
							<div class="flex justify-between text-teal-600 font-bold">
								<span>RUT deduction (50% tax discount on labor)</span>
								<span class="font-mono">-1,560 SEK</span>
							</div>
							<div class="flex justify-between text-sm font-extrabold text-text-heading pt-2 border-t border-slate-100">
								<span>Your price to pay per month</span>
								<span class="font-mono text-accent">1,560 SEK</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ FAQ ═══════════════════ -->
	<section class="bg-white py-20 md:py-28 border-t border-slate-100">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest font-mono">FAQ</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-2 mb-4">Frequently Asked Questions</h2>
			</div>

			<div class="space-y-1 reveal-on-scroll">
				{[
					{
						q: 'Do I get the same cleaner every time?',
						a: 'Yes, absolutely. We always aim to send the same cleaner to your home. This builds trust, increases cleaning efficiency, and ensures they learn your preferences. In case of sickness or holidays, we offer a qualified substitute.'
					},
					{
						q: 'How does key management work?',
						a: 'We handle your keys securely. Keys are registered and stored in a secure key safe. They are labeled with a unique code (never with your name or address) for safety.'
					},
					{
						q: 'Do I need to be home when you clean?',
						a: 'No, you do not need to be home. Most of our clients are at work or away during cleaning hours. You can safely hand over a key or arrange for entry.'
					},
					{
						q: 'Are cleaning supplies included?',
						a: 'Yes, for subscription clients and regular cleanings, eco-friendly cleaning supplies are fully included in the hourly rate. We bring everything needed.'
					}
				].map((faq, idx) => (
					<div class="border-b border-slate-100 last:border-b-0">
						<button
							id={`faq-btn-${idx}`}
							class="faq-trigger w-full flex justify-between items-center py-5 text-left font-bold text-text-heading hover:text-accent transition-colors cursor-pointer outline-none group"
							aria-expanded="false"
						>
							<span class="text-base md:text-lg pr-4">{faq.q}</span>
							<span class="faq-icon text-text-muted flex-shrink-0 transition-transform duration-300 group-aria-expanded:rotate-180">
								<svg class="w-5 h-5 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
							</span>
						</button>
						<div id={`faq-content-${idx}`} class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
							<div class="pb-5 text-text-body text-base leading-relaxed">
								{faq.a}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══════════════════ CTA ═══════════════════ -->
	<section class="py-20 bg-[#040a18] relative">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
		<div class="max-w-3xl mx-auto px-6 text-center reveal-on-scroll">
			<h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-5">Enjoy a cleaner home</h2>
			<p class="text-slate-400 text-base leading-relaxed mb-8 max-w-lg mx-auto">Contact us today to schedule a home visit or request a quick quote for regular home cleaning services.</p>
			<div class="flex flex-wrap items-center justify-center gap-4">
				<a href="/en/contact?service=hemstadning" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-lg shadow-teal-900/30">
					Get a quote
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
				</a>
				<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-700 text-sm font-bold text-slate-300 hover:bg-slate-800 transition-colors">
					Call us
				</a>
			</div>
		</div>
	</section>

</main>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (window.initGlowCards) window.initGlowCards();
		if (window.initTiltCards) window.initTiltCards();

		// FAQ accordion toggle
		document.querySelectorAll('.faq-trigger').forEach(trigger => {
			trigger.addEventListener('click', () => {
				const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
				const contentId = trigger.id.replace('btn', 'content');
				const content = document.getElementById(contentId);

				document.querySelectorAll('.faq-trigger').forEach(ot => {
					if (ot !== trigger) {
						ot.setAttribute('aria-expanded', 'false');
						const oId = ot.id.replace('btn', 'content');
						const oC = document.getElementById(oId);
						if (oC) oC.style.maxHeight = null;
					}
				});

				trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
				if (content) content.style.maxHeight = isExpanded ? null : content.scrollHeight + 'px';
			});
		});
	});
</script>
</Layout>
