---
import Layout from '../../layouts/Layout.astro';
import flyttIcon from '../../icons/Flyttjänster.png';
import hemstadningIcon from '../../icons/Hemstädning.png';
import fonsterputsningIcon from '../../icons/Fönsterputsning.png';
import takrengoringIcon from '../../icons/Takrengöring.png';
import tradgardsvardIcon from '../../icons/Trädgårdsvård.png';
import flyttImg from '../../images/Flyttjänster.png';
---

<Layout title="Sonvice Group | Professional Moving & Cleaning in Stockholm" description="Premium moving and cleaning services in Stockholm. We offer residential relocation, home cleaning, window washing, and roof care with a satisfaction guarantee.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO SECTION ═══════════════════ -->
	<section class="relative bg-white pt-12 pb-24 md:py-32 bg-grid-pattern">
		<!-- Canvas Particle Background -->
		<canvas id="hero-particles" class="absolute inset-0 w-full h-full pointer-events-none -z-5 opacity-60"></canvas>
		<!-- Glowing ambient light -->
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] -z-10 pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[20%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] -z-10 pointer-events-none animate-float-delay"></div>

		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
				
				<!-- Text Side (col-span-7) -->
				<div class="lg:col-span-7 space-y-8 reveal-on-scroll">
					<!-- Styled Opener Badge -->
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
						</span>
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Stockholm's Premium Partner</span>
					</div>

					<h1 class="text-4xl md:text-5xl lg:text-[3.8rem] font-extrabold tracking-tight text-text-heading leading-[1.05]">
						Your moving & cleaning – <br/>
						<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
							<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">easier</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">safer</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">faster</span>
						</span>
						<span class="block md:inline-block">than ever</span>
					</h1>
					
					<p class="text-lg text-text-body leading-relaxed max-w-xl">
						From home relocation to crystal clear windows. We deliver domestic services of the highest standard with trained staff and full liability insurance via Trygg-Hansa.
					</p>

					<div class="flex flex-wrap items-center gap-4 pt-2">
						<a href="/en/contact" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm cursor-pointer">
							Get free quote
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Call 08-123 45 67
						</a>
					</div>

					<!-- Trust Strip -->
					<div class="flex flex-wrap items-center gap-x-6 gap-y-3 pt-6 border-t border-slate-100 text-sm text-slate-500">
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
							Trygg-Hansa Insured
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							100% Satisfaction Guarantee
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							Direct RUT Tax Deduction
						</span>
					</div>
				</div>

				<!-- Image Side (col-span-5) -->
				<div class="lg:col-span-5 relative reveal-on-scroll delay-200">
					<!-- Geometric background outline decorative element -->
					<div class="absolute -inset-4 border border-dashed border-slate-200/80 rounded-3xl -z-10 pointer-events-none"></div>
					
					<div class="tilt-card rounded-2xl overflow-hidden aspect-[4/3] bg-slate-50 border border-slate-200/60 shadow-md">
						<img src={flyttImg.src} alt="Sonvice Group relocation" class="w-full h-full object-cover transition-transform duration-700 tilt-inner" />
					</div>
					
					<!-- Interactive Floating Stat Panel -->
					<div class="absolute -bottom-6 -left-6 md:bottom-8 md:-left-8 glass-panel rounded-xl shadow-lg p-5 border border-slate-200/80 max-w-[200px]">
						<div class="text-3xl font-extrabold text-accent" data-count-to="500" data-count-suffix="+">0+</div>
						<div class="text-xs text-text-heading font-bold uppercase tracking-wider mt-1">Happy Customers</div>
						<p class="text-[10px] text-text-muted mt-1 leading-normal">Active collaborations throughout the Stockholm region.</p>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- ═══════════════════ TRUST TICKER MARQUEE ═══════════════════ -->
	<div class="relative w-full py-6 bg-slate-900 border-y border-slate-800 overflow-hidden z-10">
		<div class="animate-marquee whitespace-nowrap flex items-center gap-16 text-slate-300 font-bold uppercase tracking-wider text-xs">
			<span>🛡️ Trygg-Hansa Insured</span>
			<span>⭐ 100% Satisfaction Guarantee</span>
			<span>✍️ Direct RUT Tax Deduction</span>
			<span>🚛 Secure Transports in Stockholm</span>
			<span>👷 Professionally Trained Staff</span>
			<span>💼 F-skatt Approved</span>
			<span>⏱️ Quick Free Quotes</span>
			
			<!-- Duplicate for seamless scrolling -->
			<span>🛡️ Trygg-Hansa Insured</span>
			<span>⭐ 100% Satisfaction Guarantee</span>
			<span>✍️ Direct RUT Tax Deduction</span>
			<span>🚛 Secure Transports in Stockholm</span>
			<span>👷 Professionally Trained Staff</span>
			<span>💼 F-skatt Approved</span>
			<span>⏱️ Quick Free Quotes</span>
		</div>
	</div>


	<!-- ═══════════════════ HOW IT WORKS ═══════════════════ -->

	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-200/80 to-transparent"></div>
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">It's simple</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">How it works</h2>
				<p class="text-text-body text-base leading-relaxed">From inquiry to completed job — three easy steps. We handle the rest.</p>
			</div>
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 relative">
				<div id="process-step-1" class="process-connector relative text-center reveal-on-scroll">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">1</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card">
						<div class="text-4xl mb-4">📋</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">Contact us</h3>
						<p class="text-sm text-text-body leading-relaxed">Fill in our form or give us a call. Tell us what you need — moving, cleaning, or anything else.</p>
					</div>
				</div>
				<div id="process-step-2" class="process-connector relative text-center reveal-on-scroll delay-200">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">2</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card">
						<div class="text-4xl mb-4">💬</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">Get a quote</h3>
						<p class="text-sm text-text-body leading-relaxed">Within 24 hours we send a tailored quote with no hidden fees. No obligations.</p>
					</div>
				</div>
				<div class="relative text-center reveal-on-scroll delay-400">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">3</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card">
						<div class="text-4xl mb-4">✅</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">We handle the rest</h3>
						<p class="text-sm text-text-body leading-relaxed">Our trained team arrives on time and completes the job professionally. Pay simply with RUT tax credit.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ SERVICES SECTION ═══════════════════ -->
	<section class="bg-surface-warm py-20 md:py-28 relative">
		<!-- Subtle ambient warm background glow -->
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>

		<div class="max-w-6xl mx-auto px-6">
			
			<!-- Section Header -->
			<div class="max-w-2xl mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Services</span>
				<h2 class="text-3xl md:text-5xl font-bold text-text-heading tracking-tight mt-3 mb-4">
					Premium service under one roof
				</h2>
				<p class="text-text-body text-base leading-relaxed">
					We offer full-service solutions for your domestic needs. Select a service below and request a quote.
				</p>
			</div>

			<!-- Services Grid -->
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				
				<!-- Service Card: Flytt -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={flyttIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Moving Services</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Home moves, packing, carrying assistance, and secure transport. We move your home safely and smoothly.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">From 450 SEK/hr</span>
						<a href="/en/moving-services" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Read more <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Service Card: Hemstädning -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={hemstadningIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Home Cleaning</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Regular weekly cleaning or one-off sessions. Eco-friendly methods with sparkling results.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">From 195 SEK/hr</span>
						<a href="/en/home-cleaning" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Read more <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Service Card: Fönsterputsning -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={fonsterputsningIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Window Cleaning</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Streak-free crystal clear windows. We wash homes, apartments, and offices with the highest precision.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">From 390 SEK fixed</span>
						<a href="/en/window-cleaning" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Read more <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Service Card: Takrengöring -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={takrengoringIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Roof Cleaning</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Gentle washing and moss treatment. We extend your roof's lifespan and remove moss effectively.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">From 1 900 SEK</span>
						<a href="/en/roof-cleaning" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Read more <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Service Card: Trädgårdsvård -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={tradgardsvardIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Gardening</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Lawn mowing, hedge trimming, and leaf clearance. We keep your garden pristine all season.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">From 295 SEK/hr</span>
						<a href="/en/gardening" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Read more <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Promo Combo Card -->
				<div class="bg-gradient-to-br from-teal-700 to-emerald-800 rounded-2xl p-8 text-white flex flex-col justify-between shadow-md relative overflow-hidden">
					<div class="absolute -right-10 -bottom-10 w-32 h-32 bg-teal-500/20 rounded-full blur-2xl"></div>
					<div>
						<span class="text-[10px] font-bold text-teal-200 uppercase tracking-widest bg-teal-900/40 px-2.5 py-1 rounded-md">Combo Offer</span>
						<h3 class="text-xl font-bold mt-4 mb-3">Need both moving & cleaning?</h3>
						<p class="text-sm text-teal-100/90 leading-relaxed mb-6">
							Combine your home relocation with end-of-tenancy cleaning and get a customized package price with a discount.
						</p>
					</div>
					<a href="/en/contact" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-lg bg-white text-teal-900 font-bold text-sm hover:bg-teal-50 transition-colors shadow-xs active:scale-[0.98]">
						Request combo quote
						<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
					</a>
				</div>

			</div>
		</div>
	</section>

	<!-- ═══════════════════ INTERACTIVE PRICE CALCULATOR ═══════════════════ -->
	<section class="py-20 bg-white relative overflow-hidden bg-grid-pattern border-t border-slate-100">
		<div class="absolute top-[30%] left-[-10%] w-[350px] h-[350px] bg-glow-teal rounded-full blur-[80px] pointer-events-none"></div>
		
		<div class="max-w-4xl mx-auto px-6 relative">
			<div class="text-center max-w-2xl mx-auto mb-12 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Price Estimator</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">
					Calculate your price estimate instantly
				</h2>
				<p class="text-text-body text-sm leading-relaxed">
					Select service and size below to get an instant estimation. You can request a quote with your chosen parameters.
				</p>
			</div>

			<!-- Calculator Box -->
			<div class="glass-panel bg-white/95 rounded-3xl p-8 md:p-10 border border-slate-200/80 shadow-xl max-w-2xl mx-auto reveal-on-scroll delay-100">
				<!-- Service Tabs -->
				<div class="grid grid-cols-3 gap-2 p-1.5 bg-slate-100 rounded-xl mb-8">
					<button id="calc-tab-moving" class="calc-tab py-3 px-2 text-[11px] md:text-sm font-bold rounded-lg transition-all text-accent bg-white shadow-xs focus:outline-none" data-service="moving">
						📦 Moving Help
					</button>
					<button id="calc-tab-cleaning" class="calc-tab py-3 px-2 text-[11px] md:text-sm font-bold rounded-lg transition-all text-slate-500 hover:text-slate-800 focus:outline-none" data-service="cleaning">
						✨ Home Cleaning
					</button>
					<button id="calc-tab-roof" class="calc-tab py-3 px-2 text-[11px] md:text-sm font-bold rounded-lg transition-all text-slate-500 hover:text-slate-800 focus:outline-none" data-service="roof">
						🏠 Roof Cleaning
					</button>
				</div>

				<div class="space-y-6">
					<!-- Size Slider -->
					<div>
						<div class="flex justify-between items-center mb-2">
							<label for="calc-size" id="calc-size-label" class="text-sm font-bold text-text-heading">Property size (square meters)</label>
							<span id="calc-size-val" class="text-base font-extrabold text-accent bg-accent-soft px-3 py-1 rounded-md font-mono">60 m²</span>
						</div>
						<input type="range" id="calc-size" min="15" max="250" value="60" class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-accent" />
						<div class="flex justify-between text-[11px] text-slate-400 font-medium mt-1">
							<span>15 m²</span>
							<span>100 m²</span>
							<span>200 m²</span>
							<span>250 m²</span>
						</div>
					</div>

					<!-- RUT/ROT and details warning info -->
					<div id="calc-info-cleaning" class="hidden p-4 rounded-xl bg-teal-50/50 border border-teal-100 text-xs text-teal-800 leading-relaxed">
						<strong>✨ Home Cleaning & RUT Tax Credit:</strong> The Swedish Tax Agency pays 50% of the labor cost directly on the invoice. We manage the entire application for you. Price includes all cleaning materials.
					</div>
					<div id="calc-info-moving" class="p-4 rounded-xl bg-slate-50/50 border border-slate-200/80 text-xs text-slate-600 leading-relaxed">
