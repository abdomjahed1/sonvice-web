<!-- JS testimonial carousel & FAQ triggers -->
<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		// --- Testimonials Slider Logic ---
		const slides = document.querySelectorAll('.testimonial-slide');
		const prevBtn = document.getElementById('prev-testimonial');
		const nextBtn = document.getElementById('next-testimonial');
		let currentIdx = 0;

		const showSlide = (idx) => {
			slides.forEach((slide, i) => {
				if (i === idx) {
					slide.classList.remove('hidden');
					setTimeout(() => {
						slide.classList.add('opacity-100', 'translate-x-0');
						slide.classList.remove('opacity-0', 'translate-x-8');
					}, 20);
				} else {
					slide.classList.add('hidden', 'opacity-0', 'translate-x-8');
					slide.classList.remove('opacity-100', 'translate-x-0');
				}
			});
		};

		if (prevBtn && nextBtn && slides.length) {
			nextBtn.addEventListener('click', () => {
				currentIdx = (currentIdx + 1) % slides.length;
				showSlide(currentIdx);
			});

			prevBtn.addEventListener('click', () => {
				currentIdx = (currentIdx - 1 + slides.length) % slides.length;
				showSlide(currentIdx);
			});
		}

		// --- FAQ accordion toggle ---
		document.querySelectorAll('.faq-trigger').forEach(trigger => {
			trigger.addEventListener('click', () => {
				const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
				const contentId = trigger.id.replace('btn', 'content');
				const content = document.getElementById(contentId);
				const icon = trigger.querySelector('.faq-icon');

				document.querySelectorAll('.faq-trigger').forEach(ot => {
					if (ot !== trigger) {
						ot.setAttribute('aria-expanded', 'false');
						const oId = ot.id.replace('btn', 'content');
						const oC = document.getElementById(oId);
						if (oC) oC.style.maxHeight = null;
						const oI = ot.querySelector('.faq-icon');
						if (oI) oI.textContent = '+';
					}
				});

				trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
				if (content) content.style.maxHeight = isExpanded ? null : content.scrollHeight + 'px';
				if (icon) {
					icon.textContent = isExpanded ? '+' : '−';
				}
			});
		});

		// --- Word Cycler Logic ---
		const words = document.querySelectorAll('.cycling-word');
		if (words.length > 1) {
			let wordIdx = 0;
			setInterval(() => {
				words[wordIdx].classList.remove('active');
				wordIdx = (wordIdx + 1) % words.length;
				words[wordIdx].classList.add('active');
			}, 2500);
		}

		// --- Pricing Calculator Logic ---
		const tabMoving = document.getElementById('calc-tab-moving');
		const tabCleaning = document.getElementById('calc-tab-cleaning');
		const tabRoof = document.getElementById('calc-tab-roof');
		const sizeLabel = document.getElementById('calc-size-label');
		const sizeInput = document.getElementById('calc-size');
		const sizeVal = document.getElementById('calc-size-val');
		const priceVal = document.getElementById('calc-price-val');
		const infoMoving = document.getElementById('calc-info-moving');
		const infoCleaning = document.getElementById('calc-info-cleaning');
		const infoRoof = document.getElementById('calc-info-roof');
		const savingsNote = document.getElementById('calc-savings-note');
		const savingsVal = document.getElementById('calc-savings-val');
		const minNote = document.getElementById('calc-min-note');
		const standardNote = document.getElementById('calc-standard-note');
		const ctaBtn = document.getElementById('calc-cta-btn');

		let currentService = 'moving';

		const updateCalculator = () => {
			if (!sizeInput) return;
			const size = parseInt(sizeInput.value, 10);
			if (sizeVal) sizeVal.textContent = `${size} m²`;

			let finalPrice = 0;
			let displaySavings = false;
			let displayMinApplied = false;
			let savingsAmount = 0;

			if (currentService === 'moving') {
				if (sizeLabel) sizeLabel.textContent = 'Property size (square meters)';
				// Moving: 1200 base + 45 kr per sqm
				finalPrice = 1200 + (size * 45);
				if (infoMoving) infoMoving.classList.remove('hidden');
				if (infoCleaning) infoCleaning.classList.add('hidden');
				if (infoRoof) infoRoof.classList.add('hidden');
				if (savingsNote) savingsNote.classList.add('hidden');
				if (minNote) minNote.classList.add('hidden');
				if (standardNote) standardNote.classList.remove('hidden');
			} else if (currentService === 'cleaning') {
				if (sizeLabel) sizeLabel.textContent = 'Property size (square meters)';
				// Cleaning: 600 base + 30 kr per sqm. RUT-avdrag 50% discount.
				const basePrice = 600 + (size * 30);
				finalPrice = basePrice * 0.5; // 50% RUT
				savingsAmount = basePrice * 0.5;
				displaySavings = true;
				if (infoMoving) infoMoving.classList.add('hidden');
				if (infoCleaning) infoCleaning.classList.remove('hidden');
				if (infoRoof) infoRoof.classList.add('hidden');
				if (savingsNote) savingsNote.classList.remove('hidden');
				if (minNote) minNote.classList.add('hidden');
				if (standardNote) standardNote.classList.add('hidden');
			} else if (currentService === 'roof') {
				if (sizeLabel) sizeLabel.textContent = 'Roof size (square meters)';
				// Roof cleaning: 56 kr/sqm (gets to ~39 kr/sqm after 30% ROT)
				// Min charge is 4,500 kr before ROT
				let basePrice = size * 56;
				if (basePrice < 4500) {
					basePrice = 4500;
					displayMinApplied = true;
				}
				finalPrice = basePrice * 0.7; // 30% ROT
				savingsAmount = basePrice * 0.3; // 30% savings
				displaySavings = true;

				if (infoMoving) infoMoving.classList.add('hidden');
				if (infoCleaning) infoCleaning.classList.add('hidden');
				if (infoRoof) infoRoof.classList.remove('hidden');
				if (savingsNote) savingsNote.classList.remove('hidden');
				if (minNote) {
					if (displayMinApplied) minNote.classList.remove('hidden');
					else minNote.classList.add('hidden');
				}
				if (standardNote) standardNote.classList.add('hidden');
			}

			if (priceVal) priceVal.textContent = Math.round(finalPrice).toLocaleString('en-US');
			if (savingsNote && displaySavings && savingsVal) {
				savingsVal.textContent = Math.round(savingsAmount).toLocaleString('en-US');
				
				// Update label for ROT or RUT
				if (currentService === 'roof') {
					savingsNote.innerHTML = `Your price after ROT tax credit (You save <span id="calc-savings-val" class="font-mono">${Math.round(savingsAmount).toLocaleString('en-US')}</span> kr)`;
				} else {
					savingsNote.innerHTML = `Your price after RUT tax credit (You save <span id="calc-savings-val" class="font-mono">${Math.round(savingsAmount).toLocaleString('en-US')}</span> kr)`;
				}
			}
			if (ctaBtn) {
				ctaBtn.setAttribute('href', `/en/contact?service=${currentService}&size=${size}`);
			}
		};

		if (tabMoving && tabCleaning && tabRoof && sizeInput) {
			const setTabActive = (activeTab, inactiveTab1, inactiveTab2, service) => {
				currentService = service;
				activeTab.classList.add('bg-white', 'text-accent', 'shadow-xs');
				activeTab.classList.remove('text-slate-500', 'hover:text-slate-800');
				
				inactiveTab1.classList.remove('bg-white', 'text-accent', 'shadow-xs');
				inactiveTab1.classList.add('text-slate-500', 'hover:text-slate-800');
				
				inactiveTab2.classList.remove('bg-white', 'text-accent', 'shadow-xs');
				inactiveTab2.classList.add('text-slate-500', 'hover:text-slate-800');
				
				updateCalculator();
			};

			tabMoving.addEventListener('click', () => setTabActive(tabMoving, tabCleaning, tabRoof, 'moving'));
			tabCleaning.addEventListener('click', () => setTabActive(tabCleaning, tabMoving, tabRoof, 'cleaning'));
			tabRoof.addEventListener('click', () => setTabActive(tabRoof, tabMoving, tabCleaning, 'roof'));

			sizeInput.addEventListener('input', updateCalculator);
			updateCalculator();
		}

		// Initialize Mouse Spotlights
		if (window.initGlowCards) {
			window.initGlowCards();
		}
		if (window.initTiltCards) {
			window.initTiltCards();
		}

		// --- Process Connector Lines ---
		const procSteps = document.querySelectorAll('#process-step-1, #process-step-2');
		const procObserver = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					setTimeout(() => entry.target.classList.add('connector-active'), 600);
				}
			});
		}, { threshold: 0.5 });
		procSteps.forEach(el => procObserver.observe(el));

		// --- Canvas Particle System (Optimized with IntersectionObserver) ---
		const canvas = document.getElementById('hero-particles');
		if (canvas) {
			const ctx = canvas.getContext('2d');
			let W = canvas.parentElement.offsetWidth;
			let H = canvas.parentElement.offsetHeight;
			canvas.width = W;
			canvas.height = H;
			const resize = () => {
				W = canvas.parentElement.offsetWidth;
				H = canvas.parentElement.offsetHeight;
				canvas.width = W;
				canvas.height = H;
			};
			window.addEventListener('resize', resize);
			const PARTICLE_COUNT = 55;
			const MAX_DIST = 130;
			let mouseX = -999, mouseY = -999;
			canvas.parentElement.addEventListener('mousemove', (e) => {
				const rect = canvas.getBoundingClientRect();
				mouseX = e.clientX - rect.left;
				mouseY = e.clientY - rect.top;
			});
			const particles = Array.from({ length: PARTICLE_COUNT }, () => ({
				x: Math.random() * W,
				y: Math.random() * H,
				vx: (Math.random() - 0.5) * 0.4,
				vy: (Math.random() - 0.5) * 0.4,
				r: Math.random() * 2 + 1,
			}));

			let isVisible = true;
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					const wasVisible = isVisible;
					isVisible = entry.isIntersecting;
					if (isVisible && !wasVisible) {
						// Resume animation loop
						drawFrame();
					}
				});
			}, { threshold: 0.05 });
			observer.observe(canvas);

			const drawFrame = () => {
				if (!isVisible) return;
				ctx.clearRect(0, 0, W, H);
				particles.forEach(p => {
					p.x += p.vx;
					p.y += p.vy;
					if (p.x < 0 || p.x > W) p.vx *= -1;
					if (p.y < 0 || p.y > H) p.vy *= -1;
					const dx = p.x - mouseX;
					const dy = p.y - mouseY;
					const dist = Math.sqrt(dx * dx + dy * dy);
					if (dist < 80) {
						const force = (80 - dist) / 80;
						p.x += (dx / dist) * force * 2;
						p.y += (dy / dist) * force * 2;
					}
					ctx.beginPath();
					ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
					ctx.fillStyle = 'rgba(13,148,136,0.5)';
					ctx.fill();
				});
				for (let i = 0; i < particles.length; i++) {
					for (let j = i + 1; j < particles.length; j++) {
						const dx = particles[i].x - particles[j].x;
						const dy = particles[i].y - particles[j].y;
						const d = Math.sqrt(dx * dx + dy * dy);
						if (d < MAX_DIST) {
							ctx.beginPath();
							ctx.moveTo(particles[i].x, particles[i].y);
							ctx.lineTo(particles[j].x, particles[j].y);
							ctx.strokeStyle = `rgba(13,148,136,${(1 - d / MAX_DIST) * 0.18})`;
							ctx.lineWidth = 0.8;
							ctx.stroke();
						}
					}
				}
				requestAnimationFrame(drawFrame);
			};
			drawFrame();
		}
	});
</script>

