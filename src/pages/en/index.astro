---
import Layout from '../../layouts/Layout.astro';
import flyttIcon from '../../icons/Flyttjänster.webp';
import hemstadningIcon from '../../icons/Hemstädning.webp';
import fonsterputsningIcon from '../../icons/Fönsterputsning.webp';
import takrengoringIcon from '../../icons/Takrengöring.webp';
import tradgardsvardIcon from '../../icons/Trädgårdsvård.webp';
import flyttImg from '../../images/Flyttjänster.webp';
import bgImg from '../../images/web-background.webp';
import bgImgMobile from '../../images/web-backround-mobile.webp';
---

<Layout title="Sonvice Group | Professional Moving & Cleaning in Kronoberg/Kalmar" description="Premium moving and cleaning services in Kronoberg/Kalmar. We offer residential relocation, home cleaning, window washing, and roof care with a satisfaction guarantee.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO SECTION ═══════════════════ -->
	<section class="relative pt-12 pb-24 md:py-32 bg-white overflow-hidden">
		<!-- Mobile Background Image Container -->
		<div class="absolute inset-0 bg-cover bg-bottom bg-no-repeat md:hidden" style={{ backgroundImage: `url(${bgImgMobile.src})` }}></div>
		<!-- Desktop Background Image Container -->
		<div class="hidden md:block absolute inset-0 bg-cover md:bg-[position:center_40%] bg-center bg-no-repeat" style={{ backgroundImage: `url(${bgImg.src})` }}></div>
		<!-- Readable Gradient Overlay -->
		<div class="absolute inset-0 bg-gradient-to-b from-white/80 via-white/50 to-white/85"></div>
		<!-- Canvas Particle Background -->
		<canvas id="hero-particles" class="absolute inset-0 w-full h-full pointer-events-none opacity-60"></canvas>
		<!-- Glowing ambient light -->
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[20%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] pointer-events-none animate-float-delay"></div>

		<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
			<div class="space-y-8 reveal-on-scroll flex flex-col items-center">
				<!-- Styled Opener Badge -->
				<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
					</span>
					<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Kronoberg/Kalmar's Premium Partner</span>
				</div>

				<h1 class="text-4xl md:text-5xl lg:text-[3.8rem] font-extrabold tracking-tight text-text-heading leading-[1.05]">
					Your moving & cleaning – <br/>
					<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
						<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">easier</span>
						<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">safer</span>
						<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">faster</span>
					</span>
					<span class="block md:inline-block">than ever</span>
				</h1>

			<div class="h-16 md:h-20"></div>

			<div class="flex flex-wrap items-center justify-center gap-4 pt-2">
					<a href="/en/contact" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm cursor-pointer">
						Get free quote
						<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
					</a>
					<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
						Call 08-123 45 67
					</a>
				</div>

				<!-- Trust Strip -->
				<div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 pt-6 border-t border-slate-200/80 text-sm text-slate-800 font-semibold text-center w-full">
					<span class="flex items-center gap-2 font-medium">
						<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
						Trygg-Hansa Insured
					</span>
					<span class="flex items-center gap-2 font-medium">
						<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
						100% Satisfaction Guarantee
					</span>
					<span class="flex items-center gap-2 font-medium">
						<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
						Direct RUT Tax Deduction
					</span>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ TRUST TICKER MARQUEE ═══════════════════ -->
	<div class="relative w-full py-6 bg-slate-900 border-y border-slate-800 overflow-hidden z-10">
		<div class="animate-marquee whitespace-nowrap flex items-center gap-16 text-slate-300 font-bold uppercase tracking-wider text-xs">
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
				Trygg-Hansa Insured
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-amber-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
				100% Satisfaction Guarantee
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
				Direct RUT Tax Deduction
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10h10zM13 16h6v-5l-3-3h-3v8z"/></svg>
				Secure Transports in Kronoberg/Kalmar
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
				Professionally Trained Staff
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
				F-skatt Approved
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
				Quick Free Quotes
			</span>
			
			<!-- Duplicate for seamless scrolling -->
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
				Trygg-Hansa Insured
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-amber-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
				100% Satisfaction Guarantee
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
				Direct RUT Tax Deduction
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1-1v10h10zM13 16h6v-5l-3-3h-3v8z"/></svg>
				Secure Transports in Kronoberg/Kalmar
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
				Professionally Trained Staff
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
				F-skatt Approved
			</span>
			<span class="flex items-center gap-2">
				<svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
				Quick Free Quotes
			</span>
		</div>
	</div>


	<!-- ═══════════════════ HOW IT WORKS ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-200/80 to-transparent"></div>
		
		<!-- Subtle ambient glowing blob behind the steps -->
		<div class="absolute top-[20%] left-[-10%] w-[450px] h-[450px] bg-glow-teal rounded-full blur-[100px] pointer-events-none -z-5"></div>
		
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">It's simple</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">How it works</h2>
				<p class="text-text-body text-base leading-relaxed">From inquiry to completed job — three easy steps. We handle the rest.</p>
			</div>
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 relative">
				<!-- Step 1 -->
				<div id="process-step-1" class="process-connector relative text-center reveal-on-scroll">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">1</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card group">
						<div class="w-16 h-16 rounded-2xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent mx-auto group-hover:scale-105 transition-transform duration-300">
							<svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
								<polyline points="14 2 14 8 20 8"></polyline>
								<line x1="16" y1="13" x2="8" y2="13"></line>
								<line x1="16" y1="17" x2="8" y2="17"></line>
								<polyline points="10 9 9 9 8 9"></polyline>
							</svg>
						</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">Contact us</h3>
						<p class="text-sm text-text-body leading-relaxed">Fill in our form or give us a call. Tell us what you need — moving, cleaning, or anything else.</p>
					</div>
				</div>
				<!-- Step 2 -->
				<div id="process-step-2" class="process-connector relative text-center reveal-on-scroll delay-200">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">2</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card group">
						<div class="w-16 h-16 rounded-2xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent mx-auto group-hover:scale-105 transition-transform duration-300">
							<svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
							</svg>
						</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">Get a quote</h3>
						<p class="text-sm text-text-body leading-relaxed">Within 24 hours we send a tailored quote with no hidden fees. No obligations.</p>
					</div>
				</div>
				<!-- Step 3 -->
				<div class="relative text-center reveal-on-scroll delay-400">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">3</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card group">
						<div class="w-16 h-16 rounded-2xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent mx-auto group-hover:scale-105 transition-transform duration-300">
							<svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
								<polyline points="22 4 12 14.01 9 11.01"></polyline>
							</svg>
						</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">We handle the rest</h3>
						<p class="text-sm text-text-body leading-relaxed">Our trained team arrives on time and completes the job professionally. Pay simply with RUT tax credit.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ SERVICES SECTION ═══════════════════ -->
	<section id="services" class="bg-surface-warm py-20 md:py-28 relative">
		<!-- Subtle ambient warm background glow -->
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>

		<div class="max-w-6xl mx-auto px-6">
			
			<!-- Section Header -->
			<div class="max-w-2xl mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Services</span>
				<h2 class="text-3xl md:text-5xl font-bold text-text-heading tracking-tight mt-3 mb-4">
					Premium service under one roof
				</h2>
				<p class="text-text-body text-base leading-relaxed">
					We offer full-service solutions for your domestic needs. Select a service below and request a quote.
				</p>
			</div>

			<!-- Services Grid -->
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				
				<!-- Service Card: Flytt -->
				<a href="/en/moving-services" class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group no-underline">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-0.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={flyttIcon.src} width={flyttIcon.width} height={flyttIcon.height} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Moving Services</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Home moves, packing, carrying assistance, and secure transport. We move your home safely and smoothly.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-600 uppercase tracking-wider">From 900 SEK/hr</span>
						<span class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Read more <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</span>
					</div>
				</a>

				<!-- Service Card: Hemstädning -->
				<a href="/en/home-cleaning" class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group no-underline">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-0.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={hemstadningIcon.src} width={hemstadningIcon.width} height={hemstadningIcon.height} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Home Cleaning</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Regular weekly cleaning or one-off sessions. Eco-friendly methods with sparkling results.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-600 uppercase tracking-wider">From 195 SEK/hr</span>
						<span class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Read more <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</span>
					</div>
				</a>

				<!-- Service Card: Fönsterputsning -->
				<a href="/en/window-cleaning" class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group no-underline">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-0.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={fonsterputsningIcon.src} width={fonsterputsningIcon.width} height={fonsterputsningIcon.height} alt="" class="w-full h-full object-contain" />
