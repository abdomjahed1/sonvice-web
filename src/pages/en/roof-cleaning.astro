---
import Layout from '../../layouts/Layout.astro';
import bgImg from '../../images/roof-service-background.webp';
import bgImgMobile from '../../images/roof-service-background-mobile.webp';

---

<Layout title="Roof Cleaning Kronoberg/Kalmar | Moss & Algae Treatment | Sonvice Group" description="Professional roof cleaning in Kronoberg/Kalmar. We remove moss, algae, and lichen and treat the roof tiles to prevent regrowth. Tax deduction with ROT credit.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO ═══════════════════ -->
	<section class="relative pt-12 pb-20 md:py-28 bg-white overflow-hidden">
		<!-- Mobile Background Image Container -->
		<div class="absolute inset-0 bg-cover bg-center bg-no-repeat md:hidden" style={{ backgroundImage: `url(${bgImgMobile.src})` }}></div>
		<!-- Desktop Background Image Container -->
		<div class="hidden md:block absolute inset-0 bg-cover md:bg-[position:center_30%] bg-center bg-no-repeat" style={{ backgroundImage: `url(${bgImg.src})` }}></div>
		<!-- Readable Gradient Overlay -->
		<div class="absolute inset-0 bg-gradient-to-b from-white/80 via-white/50 to-white/85"></div>
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[30%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] pointer-events-none animate-float-delay"></div>

		<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
		<!-- Back button -->
		<div class="mb-8 reveal-on-scroll flex justify-center">
			<a href="/en/#services" class="inline-flex items-center gap-2 text-sm font-bold text-slate-600 hover:text-accent transition-colors group">
				<svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
				</svg>
				Back to services
			</a>
		</div>
			<div class="space-y-8 reveal-on-scroll flex flex-col items-center">
				
				
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Extend Your Roof's Lifespan</span>
					</div>
					
					<h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight text-text-heading leading-[1.08]">
						<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
							<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Safe & gentle</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Durable</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Professional</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Effective</span>
						</span>
						<span class="block bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">roof cleaning in Kronoberg/Kalmar</span>
					</h1>
					
					<p class="text-lg text-slate-800 font-medium leading-relaxed max-w-xl mx-auto">
						Don't let moss ruin your roof. We clean clay and concrete tiles to remove moss, algae, lichen, and dirt. We also apply a premium anti-algae treatment to prevent regrowth for up to 4–5 years. A clean roof prevents frost cracks and leaks.
					</p>

					<div class="flex flex-wrap items-center justify-center gap-4 pt-2">
						<a href="/en/contact?service=takrengoring" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm">
							Request a free quote
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Call 08-123 45 67
						</a>
					</div>

					<div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 pt-5 border-t border-slate-200/80 text-sm text-slate-800 font-semibold text-center w-full">
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
							Trygg-Hansa liability insurance
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							30% ROT tax credit directly
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							Prevents water leaks
						</span>
					</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ WORK PROCESS ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden border-t border-slate-100">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest font-mono">Work Method</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">How do we clean your roof?</h2>
				<p class="text-text-body text-base">We work systematically and safely using modern gear and harness fall-protection.</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 reveal-on-scroll delay-100">
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">1. Inspection</h3>
					<p class="text-xs text-text-body leading-relaxed">We check the roof condition, identify cracked tiles, and make sure battens and sub-roofing felt are intact before starting.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">2. Pressure Washing</h3>
					<p class="text-xs text-text-body leading-relaxed">We clean the roof tiles from top to bottom with custom water pressure, removing all moss, dirt, and lichen without damaging the glaze.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707.707M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">3. Anti-Algae Spray</h3>
					<p class="text-xs text-text-body leading-relaxed">We spray a biodegradable anti-algae solution. It penetrates deep into the tile pores to kill microscopic roots and spores.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">4. Cleaning Up</h3>
					<p class="text-xs text-text-body leading-relaxed">We clean gutters from washed debris and pick up all fallen waste around the house, leaving your property in pristine condition.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ ROT TAX CREDIT ═══════════════════ -->
	<section class="py-20 bg-surface-warm relative border-t border-slate-100">
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>
		<div class="max-w-5xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 space-y-6 reveal-on-scroll">
					<span class="text-xs font-bold text-accent uppercase tracking-widest">ROT Deduction</span>
					<h2 class="text-3xl font-bold text-text-heading tracking-tight">ROT credit on roof cleaning</h2>
					<p class="text-sm text-text-body leading-relaxed">
						Roof washing is a home maintenance service eligible for the Swedish <strong>30% ROT tax credit</strong> on labor costs. We apply the deduction directly on your invoice and coordinate with Skatteverket. You just need to provide your property identifier (fastighetsbeteckning) and personal number at booking.
					</p>
					<div class="space-y-3 text-xs text-text-body">
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>30% skatterabatt is applied directly on the invoice.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>We manage the application details directly with Skatteverket.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Minimum labor fee is 4,500 kr before ROT (3,150 kr after ROT credit).</span>
						</div>
					</div>
				</div>
				<div class="lg:col-span-6 reveal-on-scroll delay-200">
					<div class="bg-white rounded-2xl border border-slate-200/80 shadow-xs overflow-hidden">
						<!-- Highlighted Price Header -->
						<div class="bg-gradient-to-r from-teal-50 to-emerald-50/30 p-6 border-b border-slate-100 text-center">
							<span class="text-xs font-bold text-accent uppercase tracking-widest block mb-1">Price Example (Roof of 120 sqm)</span>
							<div class="text-3xl font-extrabold text-text-heading">5,694 SEK</div>
							<p class="text-xs text-text-muted mt-1">After 30% ROT credit (incl. VAT & materials)</p>
						</div>
						
						<!-- Price Breakdown Details -->
						<div class="p-6 space-y-4">
							<div class="text-xs text-text-muted font-bold uppercase tracking-wider mb-2">Cost breakdown</div>
							
							<div class="space-y-3 text-sm">
								<div class="flex justify-between text-text-body">
									<span>Roof cleaning & treatment <span class="text-xs text-text-muted block mt-0.5">(120 sqm á 56 SEK/sqm)</span></span>
									<span class="font-semibold text-text-heading">6,720 SEK</span>
								</div>
								
								<div class="flex justify-between text-text-body">
									<span>Scaffolding and staging fee <span class="text-xs text-text-muted block mt-0.5">(not eligible for ROT)</span></span>
									<span class="font-semibold text-text-heading">990 SEK</span>
								</div>
								
								<div class="flex justify-between text-teal-600 font-medium pt-2 border-t border-slate-100">
									<span>ROT deduction <span class="text-xs text-teal-500">(30% tax discount on labor)</span></span>
									<span class="font-semibold">-2,016 SEK</span>
								</div>
							</div>
							
							<div class="bg-slate-50 rounded-xl p-4 mt-4 text-center">
								<p class="text-xs text-text-body leading-relaxed">
									Prices include VAT, materials, and staging. We manage the application details directly with Skatteverket.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ FAQ ═══════════════════ -->
	<section class="bg-white py-20 md:py-28 border-t border-slate-100">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest font-mono">FAQ</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-2 mb-4">Frequently Asked Questions</h2>
			</div>

			<div class="space-y-1 reveal-on-scroll">
				{[
					{
						q: 'Why is it harmful to have moss on the roof?',
						a: 'Moss acts like a sponge, retaining water against the roof tiles. During winter, this water freezes, leading to frost cracks. Frost damage breaks tiles and allows moisture to reach the wood framing, causing rot and leak damage.'
					},
					{
						q: 'How often does a roof need to be cleaned?',
						a: 'A roof that is mechanically cleaned and treated with algicide stays free of moss and algae for about 4 to 6 years, depending on nearby shade and trees. We recommend preventive treatment every 5 years.'
					},
					{
						q: 'Will pressure washing damage the tiles?',
						a: 'No, when executed correctly by professionals. We calibrate water pressure according to the tile age and type (concrete or clay), and we always wash downward to prevent water from pushing beneath the tiles.'
					},
					{
						q: 'Is gutter cleaning included in the service?',
						a: 'Yes, absolutely. During washing, moss drops into the gutters. We clean all gutters and check that downspouts are clear before finishing the work.'
					}
				].map((faq, idx) => (
					<div class="border-b border-slate-100 last:border-b-0">
						<button
							id={`faq-btn-${idx}`}
							class="faq-trigger w-full flex justify-between items-center py-5 text-left font-bold text-text-heading hover:text-accent transition-colors cursor-pointer outline-none group"
							aria-expanded="false"
						>
							<span class="text-base md:text-lg pr-4">{faq.q}</span>
							<span class="faq-icon text-text-muted flex-shrink-0 transition-transform duration-300 group-aria-expanded:rotate-180">
								<svg class="w-5 h-5 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
							</span>
						</button>
						<div id={`faq-content-${idx}`} class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
							<div class="pb-5 text-text-body text-base leading-relaxed">
								{faq.a}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══════════════════ CTA ═══════════════════ -->
	<section class="py-20 bg-[#040a18] relative">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
		<div class="max-w-3xl mx-auto px-6 text-center reveal-on-scroll">
			<h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-5">Protect your roof today</h2>
			<p class="text-slate-400 text-base leading-relaxed mb-8 max-w-lg mx-auto">Get in touch with us for a free roof inspection and quote. We offer fixed rates on washing and protection treatments.</p>
			<div class="flex flex-wrap items-center justify-center gap-4">
				<a href="/en/contact?service=takrengoring" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-lg shadow-teal-900/30">
					Request a free quote
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
				</a>
				<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-700 text-sm font-bold text-slate-300 hover:bg-slate-800 transition-colors">
					Call us
				</a>
			</div>
		</div>
	</section>

</main>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (window.initGlowCards) window.initGlowCards();
		if (window.initTiltCards) window.initTiltCards();

		// --- Word Cycler Logic ---
		const words = document.querySelectorAll('.cycling-word');
		if (words.length > 1) {
			let wordIdx = 0;
			setInterval(() => {
				words[wordIdx].classList.remove('active');
				wordIdx = (wordIdx + 1) % words.length;
				words[wordIdx].classList.add('active');
			}, 2500);
		}

		// FAQ accordion toggle
		document.querySelectorAll('.faq-trigger').forEach(trigger => {
			trigger.addEventListener('click', () => {
				const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
				const contentId = trigger.id.replace('btn', 'content');
				const content = document.getElementById(contentId);

				document.querySelectorAll('.faq-trigger').forEach(ot => {
					if (ot !== trigger) {
						ot.setAttribute('aria-expanded', 'false');
						const oId = ot.id.replace('btn', 'content');
						const oC = document.getElementById(oId);
						if (oC) oC.style.maxHeight = null;
					}
				});

				trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
				if (content) content.style.maxHeight = isExpanded ? null : content.scrollHeight + 'px';
			});
		});
	});
</script>
</Layout>
