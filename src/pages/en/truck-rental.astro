---
import Layout from '../../layouts/Layout.astro';
import truck2Img from '../../images/trucks/truck2.webp';
import bgImg from '../../images/truck-rental-service-background.webp';
import bgImgMobile from '../../images/truck-rental-service-background-mobile.webp';
---

<Layout title="Light Truck Rental | Sonvice Group" description="Rent a modern Iveco Daily 2019 light truck in Kronoberg/Kalmar. B-license, tail lift, insurance included. Flexible rental periods from 1 000 kr/day.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO SECTION ═══════════════════ -->
	<section class="relative pt-12 pb-24 md:py-32 bg-white overflow-hidden">
		<!-- Mobile Background Image Container -->
		<div class="absolute inset-0 bg-cover bg-center bg-no-repeat md:hidden" style={{ backgroundImage: `url(${bgImgMobile.src})` }}></div>
		<!-- Desktop Background Image Container -->
		<div class="hidden md:block absolute inset-0 bg-cover md:bg-[position:center_40%] bg-center bg-no-repeat" style={{ backgroundImage: `url(${bgImg.src})` }}></div>
		<!-- Readable Gradient Overlay -->
		<div class="absolute inset-0 bg-gradient-to-b from-white/80 via-white/50 to-white/85"></div>
		<!-- Glowing ambient light -->
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[20%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] pointer-events-none animate-float-delay"></div>

		<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
		<!-- Back button -->
		<div class="mb-8 reveal-on-scroll flex justify-center">
			<a href="/en/#services" class="inline-flex items-center gap-2 text-sm font-bold text-slate-600 hover:text-accent transition-colors group">
				<svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
				</svg>
				Back to services
			</a>
		</div>
			<div class="space-y-8 reveal-on-scroll flex flex-col items-center">
					<!-- Styled Opener Badge -->
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
						</span>
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Truck Rental Kronoberg/Kalmar</span>
					</div>

					<h1 class="text-4xl md:text-5xl lg:text-[3.8rem] font-extrabold tracking-tight text-text-heading leading-[1.05]">
						Light Truck Rental <br/>
						<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
							<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">– hassle-free transport</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">– smooth & secure</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">– affordable rates</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">– flexible booking</span>
						</span>
					</h1>

<div class="flex flex-wrap items-center justify-center gap-4 pt-2">
						<a href="/en/contact?service=lastbil" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm cursor-pointer">
							Book now
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Call 08-123 45 67
						</a>
					</div>

					<!-- Trust Strip -->
					<div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 pt-6 border-t border-slate-200/80 text-sm text-slate-800 font-semibold text-center w-full">
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
							Insurance Included
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							B-License Only
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
							Tail Lift Included
						</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ TRUST TICKER MARQUEE ═══════════════════ -->
	<div class="relative w-full py-6 bg-slate-900 border-y border-slate-800 overflow-hidden z-10">
		<div class="animate-marquee whitespace-nowrap flex items-center gap-16 text-slate-300 font-bold uppercase tracking-wider text-xs">
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2h-3V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h2m10 0a3 3 0 11-6 0m6 0a3 3 0 116 0m-9 0H9m-2 0a3 3 0 126 0"/></svg>Modern Iveco Daily 2019</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>Insurance Up To SEK 300,000</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1M12 12V3m0 0L8 7m4-4l4 4"/></svg>Rear Tail Lift Included</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 014 0m-9 3h.01M3 12h.01M3 15h.01M8 11a2 2 0 114 0 2 2 0 01-4 0zm6 3h4m-4 3h4"/></svg>B-License Is Enough</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a3 3 0 01-3-3m0 0a3 3 0 013-3m-3 3h3m-6 12V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2h6a2 2 0 002-2zM6 12h4m-4-3h4"/></svg>Low Fuel Consumption</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>130 km Free Mileage</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Flexible Rental Periods</span>
			
			<!-- Duplicate for seamless scrolling -->
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2h-3V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h2m10 0a3 3 0 11-6 0m6 0a3 3 0 116 0m-9 0H9m-2 0a3 3 0 126 0"/></svg>Modern Iveco Daily 2019</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>Insurance Up To SEK 300,000</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1M12 12V3m0 0L8 7m4-4l4 4"/></svg>Rear Tail Lift Included</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 014 0m-9 3h.01M3 12h.01M3 15h.01M8 11a2 2 0 114 0 2 2 0 01-4 0zm6 3h4m-4 3h4"/></svg>B-License Is Enough</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a3 3 0 01-3-3m0 0a3 3 0 013-3m-3 3h3m-6 12V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2h6a2 2 0 002-2zM6 12h4m-4-3h4"/></svg>Low Fuel Consumption</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>130 km Free Mileage</span>
			<span><svg class="w-4 h-4 text-accent inline-block mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Flexible Rental Periods</span>
		</div>
	</div>

	<!-- ═══════════════════ ABOUT THE SERVICE ═══════════════════ -->
	<section class="bg-surface-cool py-20 md:py-28 relative overflow-hidden">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-200/80 to-transparent"></div>

		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
				
				<!-- Text Side -->
				<div class="lg:col-span-7 space-y-6 reveal-on-scroll">
					<span class="text-xs font-bold text-accent uppercase tracking-widest">The Service</span>
					<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight">Rent a modern light truck — no hassle</h2>
					<p class="text-base text-text-body leading-relaxed">
						Our Iveco Daily 35-160 Chassis Cab is a modern 2019 model with automatic transmission (Hi-Matic) and low fuel consumption. It's perfect for private moves, deliveries, or transporting large items.
					</p>
					<p class="text-base text-text-body leading-relaxed">
						The truck comes equipped with a <strong class="text-text-heading">rear tail lift</strong> for easy loading, and you only need a standard <strong class="text-text-heading">B driving license</strong> to operate it. Every rental includes comprehensive insurance coverage up to SEK 300,000.
					</p>
					<div class="flex flex-wrap gap-3 pt-2">
						<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-accent-soft text-accent text-xs font-bold border border-accent/15">
							<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							Automatic
						</span>
						<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-accent-soft text-accent text-xs font-bold border border-accent/15">
							<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							Tail Lift
						</span>
						<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-accent-soft text-accent text-xs font-bold border border-accent/15">
							<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							B-License
						</span>
						<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-accent-soft text-accent text-xs font-bold border border-accent/15">
							<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							Insured
						</span>
					</div>
				</div>

				<!-- Image Side -->
				<div class="lg:col-span-5 relative reveal-on-scroll delay-200">
					<div class="tilt-card rounded-2xl overflow-hidden aspect-[4/3] bg-slate-50 border border-slate-200/60 shadow-md">
						<img src={truck2Img.src} width={truck2Img.width} height={truck2Img.height} alt="Iveco Daily truck side view" class="w-full h-full object-cover transition-transform duration-700 tilt-inner" />
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- ═══════════════════ ADVANTAGES SECTION ═══════════════════ -->
	<section class="bg-surface-warm py-20 md:py-28 relative">
		<!-- Subtle ambient warm background glow -->
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>

		<div class="max-w-6xl mx-auto px-6">
			
			<!-- Section Header -->
			<div class="max-w-2xl mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Advantages</span>
				<h2 class="text-3xl md:text-5xl font-bold text-text-heading tracking-tight mt-3 mb-4">
					Why rent from us?
				</h2>
				<p class="text-text-body text-base leading-relaxed">
					Everything you need for a smooth and stress-free rental experience — all included in one simple price.
				</p>
			</div>

			<!-- Advantages Grid -->
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				
				<!-- Advantage 1 -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 mb-6 group-hover:scale-105 transition-transform duration-300">
							<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2h-3V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h2m10 0a3 3 0 11-6 0m6 0a3 3 0 116 0m-9 0H9m-2 0a3 3 0 126 0"/></svg>
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Modern Iveco Daily 2019</h3>
						<p class="text-sm text-text-body leading-relaxed">
							Automatic transmission (Hi-Matic) with low fuel consumption. Comfortable to drive even on longer distances.
						</p>
					</div>
				</div>
 
				<!-- Advantage 2 -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 mb-6 group-hover:scale-105 transition-transform duration-300">
							<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1M12 12V3m0 0L8 7m4-4l4 4"/></svg>
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Rear Lift Included</h3>
						<p class="text-sm text-text-body leading-relaxed">
							The built-in hydraulic tail lift makes loading and unloading heavy items effortless — no ramps needed.
						</p>
					</div>
				</div>
 
				<!-- Advantage 3 -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 mb-6 group-hover:scale-105 transition-transform duration-300">
							<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 014 0m-9 3h.01M3 12h.01M3 15h.01M8 11a2 2 0 114 0 2 2 0 01-4 0zm6 3h4m-4 3h4"/></svg>
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">B Driving License Enough</h3>
						<p class="text-sm text-text-body leading-relaxed">
							No special commercial license required. Anyone with a standard B-license can drive this truck.
						</p>
					</div>
				</div>
 
				<!-- Advantage 4 -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 mb-6 group-hover:scale-105 transition-transform duration-300">
							<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Flexible Rental Periods</h3>
						<p class="text-sm text-text-body leading-relaxed">
							Rent for 1 day, 3 days, a full week, or longer. We adapt to your schedule and needs.
						</p>
					</div>
				</div>
 
				<!-- Advantage 5 -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 mb-6 group-hover:scale-105 transition-transform duration-300">
							<svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Insurance Included</h3>
						<p class="text-sm text-text-body leading-relaxed">
							Comprehensive coverage up to SEK 300,000. Deductible is SEK 5,000. Drive with complete peace of mind.
						</p>
					</div>
