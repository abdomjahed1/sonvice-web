---
import Layout from '../layouts/Layout.astro';
import bgImg from '../images/moving-service-background.webp';
import bgImgMobile from '../images/moving-service-background-mobile.webp';

---

<Layout title="Flyttjänster Kronoberg/Kalmar | Sonvice Group" description="Professionell flytthjälp i Kronoberg/Kalmar för privatpersoner och företag. Bohagsflytt, packning, bärhjälp och transport med ansvarsförsäkring och RUT-avdrag.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO ═══════════════════ -->
	<section class="relative pt-12 pb-20 md:py-28 bg-white overflow-hidden">
		<!-- Mobile Background Image Container -->
		<div class="absolute inset-0 bg-cover bg-bottom bg-no-repeat md:hidden" style={{ backgroundImage: `url(${bgImgMobile.src})` }}></div>
		<!-- Desktop Background Image Container -->
		<div class="hidden md:block absolute inset-0 bg-cover md:bg-[position:center_40%] bg-center bg-no-repeat" style={{ backgroundImage: `url(${bgImg.src})` }}></div>
		<!-- Readable Gradient Overlay -->
		<div class="absolute inset-0 bg-gradient-to-b from-white/80 via-white/50 to-white/85"></div>
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[30%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] pointer-events-none animate-float-delay"></div>

		<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
		<!-- Back button -->
		<div class="mb-8 reveal-on-scroll flex justify-center">
			<a href="/#services" class="inline-flex items-center gap-2 text-sm font-bold text-slate-600 hover:text-accent transition-colors group">
				<svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
				</svg>
				Tillbaka till tjänster
			</a>
		</div>
			<div class="space-y-8 reveal-on-scroll flex flex-col items-center">
				
				
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Trygg & Bekymmersfri Flytt</span>
					</div>
					
					<h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight text-text-heading leading-[1.08]">
						<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
							<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Professionell</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Smidig</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Trygg</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Effektiv</span>
						</span>
						<span class="block bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">flytthjälp i Kronoberg/Kalmar</span>
					</h1>

			<div class="h-16 md:h-20"></div>

			<div class="flex flex-wrap items-center justify-center gap-4 pt-2">
						<a href="/contact?service=flytt" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm">
							Begär gratis offert
							<svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Ring 08-123 45 67
						</a>
					</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ VAD INGÅR ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden border-t border-slate-100">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Tjänsteomfattning</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">Vad ingår i vår flytthjälp?</h2>
				<p class="text-text-body text-base leading-relaxed">Vi skräddarsyr flytten efter dina behov, men i grundtjänsten och våra tillval ingår allt som behövs.</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 reveal-on-scroll delay-100">
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
							<polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
							<line x1="12" y1="22.08" x2="12" y2="12"></line>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Packning & Material</h3>
					<p class="text-xs text-text-body leading-relaxed">Vi packar dina saker säkert och professionellt. Vi kan tillhandahålla flyttkartonger, bubbelplast och skyddspapper.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="17 11 12 6 7 11"></polyline>
							<polyline points="17 18 12 13 7 18"></polyline>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Tunga Lyft</h3>
					<p class="text-xs text-text-body leading-relaxed">Vi flyttar även tunga föremål som pianon, kassaskåp och stora möbler på ett tryggt och säkert sätt.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="1" y="3" width="15" height="13"></rect>
							<polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
							<circle cx="5.5" cy="18.5" r="2.5"></circle>
							<circle cx="18.5" cy="18.5" r="2.5"></circle>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Transport & Logistik</h3>
					<p class="text-xs text-text-body leading-relaxed">Våra rymliga, moderna och säkra flyttbilar säkerställer en snabb och trygg transport till ditt nya hem.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
							<polyline points="9 22 9 12 15 12 15 22"></polyline>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Flyttstädning</h3>
					<p class="text-xs text-text-body leading-relaxed">I samarbete med våra städexperter erbjuder vi även komplett flyttstädning med 100% nöjd-kund-garanti.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ RUT-AVDRAG ═══════════════════ -->
	<section class="py-20 bg-surface-warm relative border-t border-slate-100">
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>
		<div class="max-w-5xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 space-y-6 reveal-on-scroll">
					<span class="text-xs font-bold text-accent uppercase tracking-widest">Skatteavdrag</span>
					<h2 class="text-3xl font-bold text-text-heading tracking-tight">RUT-avdrag på flytthjälp</h2>
					<p class="text-sm text-text-body leading-relaxed">
						Som privatperson som bor och betalar skatt i Sverige har du rätt till RUT-avdrag, vilket minskar arbetskostnaden för flytt-tjänster med <strong>50%</strong>. Detta gäller för bohagstransport, packning samt bärhjälp.
					</p>
					<div class="space-y-3 text-xs text-text-body">
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Vi drar av 50% av arbetskostnaden direkt på din faktura.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Vi sköter all administration och kontakt med Skatteverket.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Du behöver bara uppge ditt personnummer vid bokningen.</span>
						</div>
					</div>
				</div>
				<div class="lg:col-span-6 reveal-on-scroll delay-200">
					<div class="bg-white rounded-2xl border border-slate-200/80 shadow-xs overflow-hidden">
						<!-- Highlighted Price Header -->
						<div class="bg-gradient-to-r from-teal-50 to-emerald-50/30 p-6 border-b border-slate-100 text-center">
							<span class="text-xs font-bold text-accent uppercase tracking-widest block mb-1">Räkneexempel flytthjälp</span>
							<div class="text-3xl font-extrabold text-text-heading">1 845 kr</div>
							<p class="text-xs text-text-muted mt-1">Efter 50% RUT-avdrag (inkl. moms & framkörning)</p>
						</div>
						
						<!-- Price Breakdown Details -->
						<div class="p-6 space-y-4">
							<div class="text-xs text-text-muted font-bold uppercase tracking-wider mb-2">Kostnadsfördelning</div>
							
							<div class="space-y-3 text-sm">
								<div class="flex justify-between text-text-body">
									<span>Arbetskostnad <span class="text-xs text-text-muted block mt-0.5">(3 timmar, 2 flyttkarlar + bil)</span></span>
									<span class="font-semibold text-text-heading">2 700 kr</span>
								</div>
								
								<div class="flex justify-between text-text-body">
									<span>Framkörningsavgift <span class="text-xs text-text-muted block mt-0.5">(ej berättigad till RUT-avdrag)</span></span>
									<span class="font-semibold text-text-heading">495 kr</span>
								</div>
								
								<div class="flex justify-between text-teal-600 font-medium pt-2 border-t border-slate-100">
									<span>RUT-avdrag <span class="text-xs text-teal-500">(50% av arbetskostnad)</span></span>
									<span class="font-semibold">-1 350 kr</span>
								</div>
							</div>
							
							<div class="bg-slate-50 rounded-xl p-4 mt-4 text-center">
								<p class="text-xs text-text-body leading-relaxed">
									Vi sköter all administration med Skatteverket direkt på fakturan. Du betalar endast det RUT-avdragna beloppet.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ PRIS & OFFERT ═══════════════════ -->
	<section class="py-20 md:py-28 bg-white relative overflow-hidden border-t border-slate-100">
		<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
			<div class="space-y-8 reveal-on-scroll flex flex-col items-center">
				<div class="lg:col-span-6 space-y-6 reveal-on-scroll">
					<span class="text-xs font-bold text-accent uppercase tracking-widest">Prisinformation</span>
					<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight">Vad kostar flytthjälp?</h2>
					<p class="text-text-body text-base leading-relaxed">Vi tror på transparens. Därför har vi fasta timpriser och tydliga paketpriser baserat på boyta eller volym.</p>
					
					<div class="space-y-4">
						<div class="flex items-start gap-4 p-4 rounded-xl border border-slate-100 bg-slate-50/50">
							<div class="w-10 h-10 rounded-lg bg-teal-50 flex items-center justify-center text-accent font-bold">1</div>
							<div>
								<h3 class="font-bold text-text-heading">Timpris</h3>
								<p class="text-sm text-text-body leading-relaxed">Från 450 kr/timme efter RUT-avdrag för två flyttkarlar och en fullt utrustad flyttbil.</p>
							</div>
						</div>
						<div class="flex items-start gap-4 p-4 rounded-xl border border-slate-100 bg-slate-50/50">
							<div class="w-10 h-10 rounded-lg bg-teal-50 flex items-center justify-center text-accent font-bold">2</div>
							<div>
								<h3 class="font-bold text-text-heading">Fast Pris (Helhetslösning)</h3>
								<p class="text-sm text-text-body leading-relaxed">För större bostäder eller längre distanser ger vi gärna ett fast pris. Allt ingår i offerten.</p>
							</div>
						</div>
					</div>
				</div>

				<div class="lg:col-span-6 reveal-on-scroll delay-200">
					<div class="glow-card glass-panel-dark bg-gradient-to-br from-slate-900 to-slate-950 text-white rounded-3xl p-8 md:p-10 border border-slate-800 shadow-xl relative overflow-hidden">
						<div class="absolute -top-[20%] -right-[20%] w-[300px] h-[300px] bg-glow-teal rounded-full blur-[80px] pointer-events-none opacity-40"></div>
						
						<h3 class="text-2xl font-bold mb-2 text-white">Få ett prisförslag</h3>
						<p class="text-slate-200 text-sm leading-relaxed mb-6">Fyll i en snabb förfrågan så återkommer vi med en skräddarsydd offert inom 24 timmar.</p>
						
						<form class="space-y-4" action="/contact">
							<input type="hidden" name="service" value="flytt" />
							<div>
								<label class="block text-xs font-bold text-slate-100 uppercase tracking-wider mb-2">Bohagsvolym (kubikmeter)</label>
								<input type="number" name="size" placeholder="t.ex. 35" class="w-full px-4 py-3 rounded-lg bg-slate-900/80 border border-slate-500 focus:border-accent text-white text-sm outline-none transition-colors placeholder:text-slate-300" required />
							</div>
							<button type="submit" class="w-full py-4 rounded-lg bg-accent hover:bg-accent-hover text-white font-bold text-sm transition-all active:scale-[0.98] shadow-lg shadow-teal-950/50 cursor-pointer">
								Gå vidare till offert →
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ FAQ ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden border-t border-slate-100">
		<div class="max-w-4xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Frågor & svar</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">Vanliga frågor om flytthjälp</h2>
			</div>

			<div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-slate-200/80 space-y-1 divide-y divide-slate-100 reveal-on-scroll">
				{[
					{
						q: 'Ingår flyttkartonger i priset?',
						a: 'Vi kan leverera högkvalitativa flyttkartonger till din dörr innan flytten mot en mindre avgift, eller låna ut dem om du väljer vårt helhetspaket. Fråga oss vid offertbegäran.'
					},
					{
						q: 'Vad händer om något går sönder under flytten?',
						a: 'Vi är fullt ansvarsförsäkrade via Trygg-Hansa. Om en olycka skulle inträffa och något av dina bohag skadas under packning, bärande eller transport, täcker vår försäkring skadorna upp till 10 miljoner kronor.'
					},
					{
						q: 'Hur lång tid tar en flytt normalt?',
						a: 'Tiden beror på boyta och mängden bohag. Som riktlinje tar en 2:a på 50-60 kvm runt 3-5 timmar för två flyttkarlar med en flyttbil. En större villa kan ta en heldag eller två dagar.'
					},
					{
						q: 'Kör ni flyttar under helger?',
						a: 'Ja, vi utför flyttar även på lördagar enligt överenskommelse, så att du slipper ta ledigt från jobbet.'
					}
				].map((faq, idx) => (
					<div class="border-b border-slate-100 last:border-b-0">
						<button
							id={`faq-btn-${idx}`}
							class="faq-trigger w-full flex justify-between items-center py-5 text-left font-bold text-text-heading hover:text-accent transition-colors cursor-pointer outline-none group"
							aria-expanded="false"
						>
							<span class="text-base md:text-lg pr-4">{faq.q}</span>
							<span class="faq-icon text-text-muted flex-shrink-0 transition-transform duration-300 group-aria-expanded:rotate-180">
								<svg class="w-5 h-5 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
							</span>
						</button>
						<div id={`faq-content-${idx}`} class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
							<div class="pb-5 text-text-body text-base leading-relaxed">
								{faq.a}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══════════════════ CTA ═══════════════════ -->
	<section class="py-20 bg-[#040a18] relative">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
		<div class="max-w-3xl mx-auto px-6 text-center reveal-on-scroll">
			<h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-5">Redo att flytta?</h2>
			<p class="text-slate-400 text-base leading-relaxed mb-8 max-w-lg mx-auto">Kontakta oss idag för en kostnadsfri offert. Vi återkopplar med ett skräddarsytt prisförslag inom 24 timmar.</p>
			<div class="flex flex-wrap items-center justify-center gap-4">
				<a href="/contact?service=flytt" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-lg shadow-teal-900/30">
					Begär offert
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
				</a>
				<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-700 text-sm font-bold text-slate-300 hover:bg-slate-800 transition-colors">
					Ring oss
				</a>
			</div>
		</div>
	</section>

</main>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (window.initGlowCards) window.initGlowCards();
		if (window.initTiltCards) window.initTiltCards();

		// --- Word Cycler Logic ---
		const words = document.querySelectorAll('.cycling-word');
		if (words.length > 1) {
			let wordIdx = 0;
			setInterval(() => {
				words[wordIdx].classList.remove('active');
				wordIdx = (wordIdx + 1) % words.length;
				words[wordIdx].classList.add('active');
			}, 2500);
		}

		// FAQ accordion toggle
		document.querySelectorAll('.faq-trigger').forEach(trigger => {
			trigger.addEventListener('click', () => {
				const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
				const contentId = trigger.id.replace('btn', 'content');
				const content = document.getElementById(contentId);

				document.querySelectorAll('.faq-trigger').forEach(ot => {
					if (ot !== trigger) {
						ot.setAttribute('aria-expanded', 'false');
						const oId = ot.id.replace('btn', 'content');
						const oC = document.getElementById(oId);
						if (oC) oC.style.maxHeight = null;
					}
				});

				trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
				if (content) content.style.maxHeight = isExpanded ? null : content.scrollHeight + 'px';
			});
		});
	});
</script>
</Layout>
