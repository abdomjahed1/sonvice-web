---
import Layout from '../layouts/Layout.astro';
import flyttIcon from '../icons/Flyttjänster.png';
import hemstadningIcon from '../icons/Hemstädning.png';
import fonsterputsningIcon from '../icons/Fönsterputsning.png';
import takrengoringIcon from '../icons/Takrengöring.png';
import tradgardsvardIcon from '../icons/Trädgårdsvård.png';
import flyttImg from '../images/Flyttjänster.png';
---

<Layout title="Sonvice Group | Professionell Flytt & Städning i Stockholm" description="Premium flytt- och städtjänster i Stockholm. Vi erbjuder bohagsflytt, hemstädning, fönsterputs och takvård med nöjd-kund-garanti.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO SECTION ═══════════════════ -->
	<section class="relative bg-white pt-12 pb-24 md:py-32 bg-grid-pattern">
		<!-- Canvas Particle Background -->
		<canvas id="hero-particles" class="absolute inset-0 w-full h-full pointer-events-none -z-5 opacity-60"></canvas>
		<!-- Glowing ambient light -->
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] -z-10 pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[20%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] -z-10 pointer-events-none animate-float-delay"></div>

		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
				
				<!-- Text Side (col-span-7) -->
				<div class="lg:col-span-7 space-y-8 reveal-on-scroll">
					<!-- Styled Opener Badge -->
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
						</span>
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Stockholms Premium Partner</span>
					</div>

					<h1 class="text-4xl md:text-5xl lg:text-[3.8rem] font-extrabold tracking-tight text-text-heading leading-[1.05]">
						Din flytt & städning – <br/>
						<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
							<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">enklare</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">tryggare</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">snabbare</span>
						</span>
						<span class="block md:inline-block">än någonsin</span>
					</h1>
					
					<p class="text-lg text-text-body leading-relaxed max-w-xl">
						Från bohagsflytt till kristallrena fönster. Vi levererar hushållsnära tjänster av högsta klass med utbildad personal och full ansvarsförsäkring via Trygg-Hansa.
					</p>

					<div class="flex flex-wrap items-center gap-4 pt-2">
						<a href="/contact" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm cursor-pointer">
							Få gratis offert
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Ring 08-123 45 67
						</a>
					</div>

					<!-- Trust Strip -->
					<div class="flex flex-wrap items-center gap-x-6 gap-y-3 pt-6 border-t border-slate-100 text-sm text-slate-500">
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
							Trygg-Hansa försäkrad
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							100% Nöjd-Kund-Garanti
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							Direkt RUT-avdrag på fakturan
						</span>
					</div>
				</div>

				<!-- Image Side (col-span-5) -->
				<div class="lg:col-span-5 relative reveal-on-scroll delay-200">
					<!-- Geometric background outline decorative element -->
					<div class="absolute -inset-4 border border-dashed border-slate-200/80 rounded-3xl -z-10 pointer-events-none"></div>
					
					<div class="tilt-card rounded-2xl overflow-hidden aspect-[4/3] bg-slate-50 border border-slate-200/60 shadow-md">
						<img src={flyttImg.src} alt="Sonvice Group flytthjälp" class="w-full h-full object-cover transition-transform duration-700 tilt-inner" />
					</div>
					
					<!-- Interactive Floating Stat Panel -->
					<div class="absolute -bottom-6 -left-6 md:bottom-8 md:-left-8 glass-panel rounded-xl shadow-lg p-5 border border-slate-200/80 max-w-[200px]">
						<div class="text-3xl font-extrabold text-accent" data-count-to="500" data-count-suffix="+">0+</div>
						<div class="text-xs text-text-heading font-bold uppercase tracking-wider mt-1">Nöjda Kunder</div>
						<p class="text-[10px] text-text-muted mt-1 leading-normal">Aktiva samarbeten i hela Stockholmsregionen.</p>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- ═══════════════════ TRUST TICKER MARQUEE ═══════════════════ -->
	<div class="relative w-full py-6 bg-slate-900 border-y border-slate-800 overflow-hidden z-10">
		<div class="animate-marquee whitespace-nowrap flex items-center gap-16 text-slate-300 font-bold uppercase tracking-wider text-xs">
			<span>🛡️ Trygg-Hansa Försäkrad</span>
			<span>⭐ 100% Nöjd-Kund-Garanti</span>
			<span>✍️ Direkt RUT-avdrag på fakturan</span>
			<span>🚛 Säkra Transporter i Stockholm</span>
			<span>👷 Professionell Utbildad Personal</span>
			<span>💼 F-skatt Godkänd</span>
			<span>⏱️ Snabba Kostnadsfria Offerter</span>
			
			<!-- Duplicate for seamless scrolling -->
			<span>🛡️ Trygg-Hansa Försäkrad</span>
			<span>⭐ 100% Nöjd-Kund-Garanti</span>
			<span>✍️ Direkt RUT-avdrag på fakturan</span>
			<span>🚛 Säkra Transporter i Stockholm</span>
			<span>👷 Professionell Utbildad Personal</span>
			<span>💼 F-skatt Godkänd</span>
			<span>⏱️ Snabba Kostnadsfria Offerter</span>
		</div>
	</div>


	<!-- ═══════════════════ HUR DET FUNGERAR ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-200/80 to-transparent"></div>
		
		<!-- Subtle ambient glowing blob behind the steps -->
		<div class="absolute top-[20%] left-[-10%] w-[450px] h-[450px] bg-glow-teal rounded-full blur-[100px] pointer-events-none -z-5"></div>
		
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Så enkelt är det</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">
					Hur det fungerar
				</h2>
				<p class="text-text-body text-base leading-relaxed">
					Från förfrågan till färdigt arbete — tre enkla steg. Vi tar hand om resten.
				</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 relative">
				<!-- Step 1 -->
				<div id="process-step-1" class="process-connector relative text-center reveal-on-scroll">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">1</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card group">
						<div class="w-16 h-16 rounded-2xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent mx-auto group-hover:scale-105 transition-transform duration-300">
							<svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
								<polyline points="14 2 14 8 20 8"></polyline>
								<line x1="16" y1="13" x2="8" y2="13"></line>
								<line x1="16" y1="17" x2="8" y2="17"></line>
								<polyline points="10 9 9 9 8 9"></polyline>
							</svg>
						</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">Kontakta oss</h3>
						<p class="text-sm text-text-body leading-relaxed">Fyll i vårt formulär eller ring oss. Berätta vad du behöver hjälp med — flytt, städning eller annat.</p>
					</div>
				</div>

				<!-- Step 2 -->
				<div id="process-step-2" class="process-connector relative text-center reveal-on-scroll delay-200">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">2</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card group">
						<div class="w-16 h-16 rounded-2xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent mx-auto group-hover:scale-105 transition-transform duration-300">
							<svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
							</svg>
						</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">Få en offert</h3>
						<p class="text-sm text-text-body leading-relaxed">Inom 24 timmar skickar vi en skräddarsydd offert utan dolda kostnader. Inga förpliktelser.</p>
					</div>
				</div>

				<!-- Step 3 -->
				<div class="relative text-center reveal-on-scroll delay-400">
					<div class="inline-flex w-14 h-14 rounded-full bg-gradient-to-br from-teal-500 to-emerald-600 items-center justify-center text-white font-extrabold text-lg shadow-lg shadow-teal-200 mb-6 mx-auto">3</div>
					<div class="bg-white rounded-2xl p-7 shadow-sm border border-slate-200/80 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 glow-card group">
						<div class="w-16 h-16 rounded-2xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent mx-auto group-hover:scale-105 transition-transform duration-300">
							<svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
								<polyline points="22 4 12 14.01 9 11.01"></polyline>
							</svg>
						</div>
						<h3 class="text-lg font-bold text-text-heading mb-2">Vi sköter resten</h3>
						<p class="text-sm text-text-body leading-relaxed">Vårt utbildade team anländer i tid och utför arbetet professionellt. Du betalar enkelt med RUT-avdrag.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ SERVICES SECTION ═══════════════════ -->
	<section class="bg-surface-warm py-20 md:py-28 relative">
		<!-- Subtle ambient warm background glow -->
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>

		<div class="max-w-6xl mx-auto px-6">
			
			<!-- Section Header -->
			<div class="max-w-2xl mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Tjänster</span>
				<h2 class="text-3xl md:text-5xl font-bold text-text-heading tracking-tight mt-3 mb-4">
					Premium service under ett och samma tak
				</h2>
				<p class="text-text-body text-base leading-relaxed">
					Vi erbjuder fullservice-lösningar för dina hushållsbehov. Välj din tjänst nedan och begär offert.
				</p>
			</div>

			<!-- Services Grid -->
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				
				<!-- Service Card: Flytt -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={flyttIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Flyttjänster</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Bohagsflytt, packning, bärhjälp och säker transport. Vi flyttar ditt hem tryggt och smidigt.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Från 450 kr/tim</span>
						<a href="/flyttjanster" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Läs mer <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Service Card: Hemstädning -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={hemstadningIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Hemstädning</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Regelbunden veckostädning eller engångstillfällen. Miljövänliga metoder med skinande resultat.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Från 195 kr/tim</span>
						<a href="/hemstadning" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Läs mer <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Service Card: Fönsterputsning -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={fonsterputsningIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Fönsterputsning</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Kristallklara fönster utan ränder. Vi putsar villor, lägenheter och kontor med högsta noggrannhet.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Från 390 kr fast</span>
						<a href="/fonsterputsning" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Läs mer <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Service Card: Takrengöring -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={takrengoringIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Takrengöring</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Skonsam tvätt och algskydd. Vi förlänger ditt taks livslängd och tar bort mossa effektivt.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Från 1 900 kr</span>
						<a href="/takrengoring" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Läs mer <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Service Card: Trädgårdsvård -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
					<div>
						<div class="w-14 h-14 rounded-xl bg-accent-soft flex items-center justify-center border border-accent/15 p-3.5 mb-6 group-hover:scale-105 transition-transform duration-300">
							<img src={tradgardsvardIcon.src} alt="" class="w-full h-full object-contain" />
						</div>
						<h3 class="text-xl font-bold text-text-heading mb-3 group-hover:text-accent transition-colors">Trädgårdsvård</h3>
						<p class="text-sm text-text-body leading-relaxed mb-6">
							Gräsklippning, häckklippning och lövrensning. Vi håller din trädgård fin under hela säsongen.
						</p>
					</div>
					<div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Från 295 kr/tim</span>
						<a href="/tradgardsvard" class="text-sm font-bold text-accent group-hover:text-accent-hover flex items-center gap-1 transition-colors">
							Läs mer <span class="group-hover:translate-x-0.5 transition-transform">→</span>
						</a>
					</div>
				</div>

				<!-- Promo Combo Card -->
				<div class="bg-gradient-to-br from-teal-700 to-emerald-800 rounded-2xl p-8 text-white flex flex-col justify-between shadow-md relative overflow-hidden">
					<div class="absolute -right-10 -bottom-10 w-32 h-32 bg-teal-500/20 rounded-full blur-2xl"></div>
					<div>
						<span class="text-[10px] font-bold text-teal-200 uppercase tracking-widest bg-teal-900/40 px-2.5 py-1 rounded-md">Kombipaket</span>
						<h3 class="text-xl font-bold mt-4 mb-3">Behöver du både flytt & städ?</h3>
						<p class="text-sm text-teal-100/90 leading-relaxed mb-6">
							Kombinera din bohagsflytt med flyttstädning och få ett skräddarsytt paketpris med rabatt.
						</p>
					</div>
					<a href="/contact" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-lg bg-white text-teal-900 font-bold text-sm hover:bg-teal-50 transition-colors shadow-xs active:scale-[0.98]">
						Begär kombioffert
						<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
					</a>
				</div>

			</div>
		</div>
	</section>

	<!-- ═══════════════════ INTERACTIVE PRICE CALCULATOR ═══════════════════ -->
	<section class="py-20 bg-white relative overflow-hidden bg-grid-pattern border-t border-slate-100">
		<div class="absolute top-[30%] left-[-10%] w-[350px] h-[350px] bg-glow-teal rounded-full blur-[80px] pointer-events-none"></div>
		
		<div class="max-w-4xl mx-auto px-6 relative">
