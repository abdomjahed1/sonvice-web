---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jobba hos oss | Sonvice Group" description="Bli en del av Sonvice Group. Sök lediga jobb inom flytt, hemstädning och takvård i Kronoberg/Kalmar. Skicka din ansökan idag.">
<main class="bg-surface-body bg-grid-pattern relative pb-20">
	<!-- Ambient lights -->
	<div class="absolute top-[10%] left-[20%] w-[350px] h-[350px] bg-glow-teal rounded-full blur-[80px] -z-10 pointer-events-none"></div>
	<div class="absolute bottom-[30%] right-[10%] w-[300px] h-[300px] bg-glow-amber rounded-full blur-[70px] -z-10 pointer-events-none"></div>

	<!-- HERO: Warm bg banner -->
	<section class="py-16 md:py-24 max-w-6xl mx-auto px-6 reveal-on-scroll">
		<div class="max-w-2xl space-y-4">
			<span class="inline-flex items-center gap-2 text-sm font-bold text-accent">
				<span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
				Vi expanderar i Kronoberg/Kalmar
			</span>
			<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-text-heading leading-[1.08]">
				Jobba hos oss
			</h1>
			<p class="text-lg md:text-xl text-text-body leading-relaxed">
				Vi söker engagerade och noggranna medarbetare till våra flytt- och städteam. Skicka din ansökan och bli en del av en rolig arbetsplats!
			</p>
		</div>
	</section>

	<!-- PERKS: Horizontal perks bar -->
	<section class="max-w-6xl mx-auto px-6 mb-20 reveal-on-scroll delay-100">
		<div class="glass-panel bg-white/70 rounded-2xl p-8 border border-slate-200/60 shadow-xs grid grid-cols-1 md:grid-cols-3 gap-8">
			
			<div class="flex items-start gap-4">
				<div class="w-10 h-10 rounded-lg bg-accent-soft border border-accent/15 flex items-center justify-center flex-shrink-0">
					<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
				</div>
				<div>
					<h3 class="font-bold text-text-heading text-sm mb-1">Trygga villkor</h3>
					<p class="text-xs text-text-body leading-relaxed">Rättvisa löner, kollektivavtalsliknande villkor och ansvarsförsäkring under arbetstid.</p>
				</div>
			</div>

			<div class="flex items-start gap-4">
				<div class="w-10 h-10 rounded-lg bg-accent-soft border border-accent/15 flex items-center justify-center flex-shrink-0">
					<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
				</div>
				<div>
					<h3 class="font-bold text-text-heading text-sm mb-1">Ett stöttande team</h3>
					<p class="text-xs text-text-body leading-relaxed">Vi hjälper varandra att leverera högsta kvalitet och skapar god sammanhållning.</p>
				</div>
			</div>

			<div class="flex items-start gap-4">
				<div class="w-10 h-10 rounded-lg bg-accent-soft border border-accent/15 flex items-center justify-center flex-shrink-0">
					<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
				</div>
				<div>
					<h3 class="font-bold text-text-heading text-sm mb-1">Flexibla arbetstider</h3>
					<p class="text-xs text-text-body leading-relaxed">Anställning på heltid, deltid eller extrapass under helger och kvällar.</p>
				</div>
			</div>
			
		</div>
	</section>

	<!-- MAIN CONTENT: Split Screen Grid -->
	<section class="max-w-6xl mx-auto px-6">
		<div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
			
			<!-- Left: Job listings (col-span-2) -->
			<div class="lg:col-span-2 space-y-4 reveal-on-scroll">
				<h2 class="text-xl font-bold text-text-heading mb-6">Lediga tjänster</h2>
				
				<!-- Job Card 1 -->
				<div class="glow-card glass-panel bg-white/95 rounded-xl p-6 hover:-translate-y-0.5 hover:shadow-md transition-all group">
					<div class="flex justify-between items-start mb-2">
						<h3 class="font-bold text-text-heading text-base group-hover:text-accent transition-colors">Flyttmedarbetare / Chaufför</h3>
					</div>
					<div class="text-xs text-text-muted font-semibold mb-3">Kronoberg/Kalmar · Heltid / Deltid</div>
					<p class="text-xs text-text-body leading-relaxed mb-4">Söker dig som gillar fysiskt arbete, är serviceinriktad och har C- eller B-körkort.</p>
					<a href="#ansok" class="inline-flex items-center gap-1 text-xs font-bold text-accent hover:text-accent-hover">Ansök nu <span class="group-hover:translate-x-0.5 transition-transform">→</span></a>
				</div>

				<!-- Job Card 2 -->
				<div class="glow-card glass-panel bg-white/95 rounded-xl p-6 hover:-translate-y-0.5 hover:shadow-md transition-all group">
					<div class="flex justify-between items-start mb-2">
						<h3 class="font-bold text-text-heading text-base group-hover:text-accent transition-colors">Hemstädare / Städpersonal</h3>
					</div>
					<div class="text-xs text-text-muted font-semibold mb-3">Kronoberg/Kalmar · Extra / Varannan vecka</div>
					<p class="text-xs text-text-body leading-relaxed mb-4">Söker noggrann personal med ett öga för renlighet och nöjda kunder.</p>
					<a href="#ansok" class="inline-flex items-center gap-1 text-xs font-bold text-accent hover:text-accent-hover">Ansök nu <span class="group-hover:translate-x-0.5 transition-transform">→</span></a>
				</div>

				<!-- Job Card 3 -->
				<div class="glow-card glass-panel bg-white/95 rounded-xl p-6 hover:-translate-y-0.5 hover:shadow-md transition-all group">
					<div class="flex justify-between items-start mb-2">
						<h3 class="font-bold text-text-heading text-base group-hover:text-accent transition-colors">Fönsterputsare / Takvårdare</h3>
					</div>
					<div class="text-xs text-text-muted font-semibold mb-3">Kronoberg/Kalmar · Säsongsanställning</div>
					<p class="text-xs text-text-body leading-relaxed mb-4">Erfarenhet av höghöjdsarbeten eller fönsterputs är starkt meriterande.</p>
					<a href="#ansok" class="inline-flex items-center gap-1 text-xs font-bold text-accent hover:text-accent-hover">Ansök nu <span class="group-hover:translate-x-0.5 transition-transform">→</span></a>
				</div>
			</div>

			<!-- Right: Application form (col-span-3) -->
			<div id="ansok" class="lg:col-span-3 scroll-mt-24 reveal-on-scroll delay-200">
				<!-- Form Card Spotlighting cursor border-glow -->
				<div class="glow-card glass-panel bg-white rounded-2xl p-8 md:p-10 border border-slate-200/60 shadow-md">
					<div id="form-container">
						<h2 class="text-2xl font-bold text-text-heading mb-2">Skicka din ansökan</h2>
						<p class="text-sm text-text-body leading-relaxed mb-6">Fyll i dina uppgifter och bifoga ditt CV nedan, så återkopplar vi inom kort.</p>
						
						<form id="application-form" method="POST" action="https://formsubmit.co/1c228acafacd5229a3e2cfb912e4107c" enctype="multipart/form-data" target="hidden-iframe" class="space-y-5">
							<!-- FormSubmit Integration (Free file uploads) -->
							<input type="hidden" name="_subject" value="Ny jobbansökan - Sonvice Group" />
							<input type="hidden" name="_captcha" value="false" />
							
							<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
								<div>
									<label for="name" class="text-sm font-semibold text-slate-700 mb-2 block">Fullständigt namn *</label>
									<input 
										type="text" 
										id="name" 
										name="name"
										required 
										placeholder="Ditt namn" 
										class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-accent focus:bg-slate-50/20 outline-none transition-all text-sm text-text-heading placeholder-text-muted" 
									/>
								</div>
								
								<div>
									<label for="email" class="text-sm font-semibold text-slate-700 mb-2 block">E-postadress *</label>
									<input 
										type="email" 
										id="email" 
										name="email"
										required 
										placeholder="namn@exempel.se" 
										class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-accent focus:bg-slate-50/20 outline-none transition-all text-sm text-text-heading placeholder-text-muted" 
									/>
								</div>
							</div>
							
							<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
								<div>
									<label for="phone" class="text-sm font-semibold text-slate-700 mb-2 block">Telefonnummer *</label>
									<input 
										type="tel" 
										id="phone" 
										name="phone"
										required 
										placeholder="070-123 45 67" 
										class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-accent focus:bg-slate-50/20 outline-none transition-all text-sm text-text-heading placeholder-text-muted" 
									/>
								</div>
								
								<div>
									<label for="job" class="text-sm font-semibold text-slate-700 mb-2 block">Sökt tjänst *</label>
									<select 
										id="job" 
										name="job"
										required 
										class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-accent outline-none transition-colors text-sm text-text-heading placeholder-text-muted cursor-pointer"
									>
										<option value="" disabled selected>Välj en tjänst...</option>
										<option value="flytt">Flyttmedarbetare / Chaufför</option>
										<option value="hemstadning">Hemstädare / Städpersonal</option>
										<option value="fonsterputs">Fönsterputsare / Takvårdare</option>
										<option value="spontan">Spontanansökan</option>
									</select>
								</div>
							</div>
							
							<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
								<div>
									<label for="find-us" class="text-sm font-semibold text-slate-700 mb-2 block">Hur hittade du oss? *</label>
									<select 
										id="find-us" 
										name="find_us"
										required 
										class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-accent outline-none transition-colors text-sm text-text-heading placeholder-text-muted cursor-pointer"
									>
										<option value="" disabled selected>Välj ett alternativ...</option>
										<option value="arbetsformedlingen">Arbetsförmedlingen</option>
										<option value="sociala_medier">Sociala medier</option>
										<option value="van_familj">Genom en vän/familjemedlem</option>
										<option value="annat">Annat (ange nedan)</option>
									</select>
								</div>
								
								<div id="find-us-other-container" class="hidden opacity-0 transition-all duration-300 transform -translate-y-2">
									<label for="find-us-other" class="text-sm font-semibold text-slate-700 mb-2 block">Ange varför/hur *</label>
									<input 
										type="text" 
										id="find-us-other" 
										name="find_us_other"
										placeholder="Skriv hur du hittade oss" 
										class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-accent focus:bg-slate-50/20 outline-none transition-all text-sm text-text-heading placeholder-text-muted" 
									/>
								</div>
							</div>

							<div>
								<label for="intro" class="text-sm font-semibold text-slate-700 mb-2 block">Kort presentation *</label>
								<textarea 
									id="intro" 
									name="intro"
									rows="4" 
									required 
									placeholder="Berätta kort om din erfarenhet och varför du vill jobba med oss..." 
									class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-accent focus:bg-slate-50/20 outline-none transition-all resize-none text-sm text-text-heading placeholder-text-muted"
								></textarea>
							</div>
							
							<div>
								<label class="text-sm font-semibold text-slate-700 mb-2 block">CV (PDF, DOCX) *</label>
								<div class="p-5 rounded-lg bg-surface-cool border border-dashed border-slate-300 flex flex-col items-center justify-center text-center">
									<input 
										type="file" 
										id="cv"
										name="attachment"
										required 
										accept=".pdf,.doc,.docx" 
										class="w-full text-sm text-text-muted file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-accent-soft file:text-accent hover:file:bg-accent-light file:cursor-pointer cursor-pointer" 
									/>
									<span class="text-xs text-text-muted mt-2">Max 10 MB. PDF- eller Word-format.</span>
								</div>
							</div>
							
							<!-- Honeypot Bot Protection (invisible to users) -->
							<div class="hidden" aria-hidden="true" style="display: none;">
								<label for="honeypot">Lämna detta fält tomt / Leave this field blank</label>
								<input type="text" id="honeypot" name="_honey" tabindex="-1" autocomplete="off" />
							</div>
							
							<button 
								type="submit" 
								id="submit-btn"
								class="group relative overflow-hidden w-full py-4 rounded-lg bg-gradient-to-r from-teal-600 to-emerald-600 hover:from-teal-500 hover:to-emerald-500 text-white font-bold text-sm transition-all flex items-center justify-center gap-2 cursor-pointer shadow-md shadow-teal-500/10 active:scale-[0.98]"
							>
								<span class="shimmer-effect"></span>
								<span id="btn-text" class="relative z-10">Skicka ansökan</span>
								<svg id="btn-icon" class="w-4 h-4 relative z-10 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
								<svg id="btn-spinner" class="w-5 h-5 animate-spin hidden relative z-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
							</button>
						</form>
					</div>

					<!-- Success State Panel -->
					<div id="success-container" class="hidden text-center py-6 space-y-6">
						<div class="mx-auto w-16 h-16 bg-teal-50 border border-teal-100 rounded-full flex items-center justify-center text-teal-600 shadow-xs animate-scale-up">
							<svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="20 6 9 17 4 12" class="animate-draw-check"></polyline>
							</svg>
						</div>

						<div class="space-y-2">
							<h2 class="text-2xl font-bold text-text-heading">Ansökan skickad!</h2>
							<p class="text-sm text-text-body leading-relaxed max-w-sm mx-auto">
								Tack <span id="success-client-name" class="font-semibold text-slate-800"></span>. Vi har tagit emot din ansökan och skickat en bekräftelse till <span id="success-client-email" class="font-semibold text-slate-800"></span>.
							</p>
						</div>

						<!-- Receipt Card -->
						<div class="bg-slate-50 border border-slate-200/80 rounded-xl p-5 text-left text-xs max-w-sm mx-auto space-y-2.5">
							<div class="flex justify-between border-b border-slate-100 pb-2">
								<span class="text-slate-400 font-semibold uppercase tracking-wider">Sökt tjänst</span>
								<span id="receipt-job" class="font-bold text-slate-700"></span>
							</div>
							<div class="flex justify-between border-b border-slate-100 pb-2">
								<span class="text-slate-400 font-semibold uppercase tracking-wider">Telefon</span>
								<span id="receipt-phone" class="font-bold text-slate-700"></span>
							</div>
							<div class="flex justify-between border-b border-slate-100 pb-2">
								<span class="text-slate-400 font-semibold uppercase tracking-wider">Bifogad fil</span>
								<span id="receipt-cv" class="font-bold text-slate-700 truncate max-w-[180px]"></span>
							</div>
							<div class="flex justify-between pt-1">
								<span class="text-slate-400 font-semibold uppercase tracking-wider">Hur du hittade oss</span>
								<span id="receipt-source" class="font-bold text-slate-700"></span>
							</div>
						</div>

						<p class="text-xs text-text-muted max-w-xs mx-auto">
							Vår rekryteringsansvarig kommer att granska din presentation och ditt CV och återkoppla till dig så snart som möjligt.
						</p>

						<div class="pt-4">
							<a href="/" class="inline-flex items-center justify-center px-6 py-2.5 rounded-lg border border-slate-200 hover:bg-slate-50 text-xs font-bold text-slate-700 transition-colors cursor-pointer">
								Tillbaka till startsidan
							</a>
						</div>
					</div>
					<!-- Hidden iframe for background submission to enable file attachments without redirect -->
					<iframe name="hidden-iframe" id="hidden-iframe" class="hidden" style="display: none;"></iframe>
				</div>
			</div>
			
		</div>
	</section>

</main>

<style>
	@keyframes drawCheck {
		to { stroke-dashoffset: 0; }
	}
	@keyframes scaleUp {
		from { transform: scale(0.8); opacity: 0; }
		to { transform: scale(1); opacity: 1; }
	}
	@keyframes shimmer {
		100% { transform: translateX(100%) skewX(-12deg); }
	}
	.animate-scale-up {
		animation: scaleUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}
	.animate-draw-check {
		stroke-dasharray: 24;
		stroke-dashoffset: 24;
		animation: drawCheck 0.5s ease-out 0.2s forwards;
	}
	.shimmer-effect {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(
			90deg,
			rgba(255, 255, 255, 0) 0%,
			rgba(255, 255, 255, 0.2) 20%,
			rgba(255, 255, 255, 0.6) 60%,
			rgba(255, 255, 255, 0) 100%
		);
		transform: translateX(-100%) skewX(-12deg);
		transition: none;
	}
	.group:hover .shimmer-effect {
		animation: shimmer 1.2s ease-in-out infinite;
	}
</style>

<!-- Mouse Spotlight Follow script initialization -->
<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (window.initGlowCards) {
			window.initGlowCards();
		}

		// Find us other field toggle
		const findUsSelect = document.getElementById('find-us');
		const otherContainer = document.getElementById('find-us-other-container');
		const otherInput = document.getElementById('find-us-other');
		if (findUsSelect && otherContainer && otherInput) {
			findUsSelect.addEventListener('change', () => {
				if (findUsSelect.value === 'annat') {
					otherContainer.classList.remove('hidden');
					// Trigger reflow
					otherContainer.offsetHeight;
					otherContainer.classList.remove('opacity-0', '-translate-y-2');
					otherContainer.classList.add('opacity-100', 'translate-y-0');
					otherInput.setAttribute('required', 'true');
				} else {
					otherContainer.classList.remove('opacity-100', 'translate-y-0');
					otherContainer.classList.add('opacity-0', '-translate-y-2');
					otherInput.removeAttribute('required');
					setTimeout(() => {
						if (findUsSelect.value !== 'annat') {
							otherContainer.classList.add('hidden');
						}
					}, 300);
				}
			});
		}

		// Form submit handler
		const applicationForm = document.getElementById('application-form');
		const formContainer = document.getElementById('form-container');
		const successContainer = document.getElementById('success-container');
		const submitBtn = document.getElementById('submit-btn');
		const btnText = document.getElementById('btn-text');
		const btnIcon = document.getElementById('btn-icon');
		const btnSpinner = document.getElementById('btn-spinner');
		const iframe = document.getElementById('hidden-iframe');

		// Success elements
		const successClientName = document.getElementById('success-client-name');
		const successClientEmail = document.getElementById('success-client-email');
		const receiptJob = document.getElementById('receipt-job');
		const receiptPhone = document.getElementById('receipt-phone');
		const receiptCv = document.getElementById('receipt-cv');
		const receiptSource = document.getElementById('receipt-source');

		if (applicationForm && formContainer && successContainer && submitBtn && iframe) {
			const pageLoadTime = Date.now();
			let isSubmitted = false;

			const showSuccessUI = () => {
				formContainer.classList.add('hidden');
				successContainer.classList.remove('hidden');
				successContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			};

			// Listen for iframe load
			iframe.addEventListener('load', () => {
				if (isSubmitted) {
					isSubmitted = false;
					showSuccessUI();
				}
			});

			applicationForm.addEventListener('submit', (e) => {
				// 1. Honeypot check (bots fill in all inputs)
				const honeyVal = document.getElementById('honeypot')?.value;
				if (honeyVal) {
					console.warn('Silent discard: bot submission detected (honeypot filled)');
					e.preventDefault();
					showSuccessUI();
					return;
				}

				// 2. Time-trap check (bots submit instantaneously, e.g. < 1.5 seconds)
				const submitTime = Date.now();
				if (submitTime - pageLoadTime < 1500) {
					console.warn('Silent discard: bot submission detected (instant submit)');
					e.preventDefault();
					showSuccessUI();
					return;
				}

				// Loading state
				isSubmitted = true;
				submitBtn.setAttribute('disabled', 'true');
				submitBtn.classList.add('opacity-80', 'cursor-not-allowed');
				if (btnText) btnText.textContent = 'Skickar...';
				if (btnIcon) btnIcon.classList.add('hidden');
				if (btnSpinner) btnSpinner.classList.remove('hidden');

				// Gather data
				const nameVal = document.getElementById('name').value;
				const emailVal = document.getElementById('email').value;
				const phoneVal = document.getElementById('phone').value;
				const jobVal = document.getElementById('job').options[document.getElementById('job').selectedIndex].text;
				const cvInput = document.getElementById('cv');
				const cvFileNameVal = cvInput && cvInput.files && cvInput.files.length > 0 ? cvInput.files[0].name : 'Ej bifogad';
				
				let sourceVal = '';
				if (findUsSelect.value === 'annat' && otherInput && otherInput.value) {
					sourceVal = `${findUsSelect.options[findUsSelect.selectedIndex].text} (${otherInput.value})`;
				} else {
					sourceVal = findUsSelect.options[findUsSelect.selectedIndex].text;
				}

				// Populate success content
				if (successClientName) successClientName.textContent = nameVal;
				if (successClientEmail) successClientEmail.textContent = emailVal;
				if (receiptJob) receiptJob.textContent = jobVal;
				if (receiptPhone) receiptPhone.textContent = phoneVal;
				if (receiptCv) receiptCv.textContent = cvFileNameVal;
				if (receiptSource) receiptSource.textContent = sourceVal;

				// Safety timeout: transition UI after 4 seconds if iframe load event is blocked/delayed
				setTimeout(() => {
					if (isSubmitted) {
						isSubmitted = false;
						showSuccessUI();
					}
				}, 4000);

				// Let form submit natively to the iframe
			});
		}
	});
</script>
</Layout>
