---
import Layout from '../layouts/Layout.astro';
import truckImg from '../images/trucks/transparent_truck.png';
import truck2Img from '../images/trucks/truck2.webp';
---

<Layout title="Lastbilsuthyrning | Sonvice Group" description="Hyr en modern och pålitlig lätt lastbil i Kronoberg/Kalmar. Iveco Daily 2019 med baklyft, B-körkort räcker. Försäkrad och flexibla hyresperioder.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO ═══════════════════ -->
	<section class="relative bg-white pt-12 pb-20 md:py-28 bg-grid-pattern">
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] -z-10 pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[30%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] -z-10 pointer-events-none animate-float-delay"></div>

		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
				
				<div class="lg:col-span-7 space-y-7 reveal-on-scroll">
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="text-lg">🚛</span>
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Ny tjänst</span>
					</div>
					
					<h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight text-text-heading leading-[1.08]">
						Lastbilsuthyrning <br/>
						<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
							<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">enkel & prisvärd</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">smidig & säker</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">flexibel & billig</span>
						</span>
					</h1>
					
					<p class="text-lg text-text-body leading-relaxed max-w-xl">
						Behöver du extra utrymme för flytt, godstransport eller andra större uppdrag? Vi erbjuder uthyrning av en modern och pålitlig lätt lastbil till mycket konkurrenskraftiga priser.
					</p>

					<div class="flex flex-wrap items-center gap-4 pt-2">
						<a href="/contact?service=lastbil" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm">
							Boka lastbil
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Ring 08-123 45 67
						</a>
					</div>

					<div class="flex flex-wrap items-center gap-x-6 gap-y-3 pt-5 border-t border-slate-100 text-sm text-slate-500">
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
							Försäkrad upp till 300 000 kr
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							B-körkort räcker
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							Baklyft ingår
						</span>
					</div>
				</div>

				<div class="lg:col-span-5 relative reveal-on-scroll delay-200">
					<div class="absolute -inset-4 border border-dashed border-slate-200/80 rounded-3xl -z-10 pointer-events-none"></div>
					<div class="tilt-card rounded-2xl overflow-hidden aspect-[4/3] bg-slate-50 border border-slate-200/60 shadow-md">
						<img src={truckImg.src} alt="Lastbil att hyra – Iveco Daily 2019" class="w-full h-full object-cover transition-transform duration-700 tilt-inner" />
					</div>
					<div class="absolute -bottom-6 -left-6 md:bottom-8 md:-left-8 glass-panel rounded-xl shadow-lg p-5 border border-slate-200/80 max-w-[200px]">
						<div class="text-2xl font-extrabold text-accent">fr. 1 000 kr</div>
						<div class="text-xs text-text-heading font-bold uppercase tracking-wider mt-1">per dag</div>
						<p class="text-[10px] text-text-muted mt-1 leading-normal">Inkl. 130 km fri körning.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ PRICING ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden border-t border-slate-100">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="max-w-5xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-14 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Priser</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">Transparent och enkel prissättning</h2>
				<p class="text-text-body text-base leading-relaxed">Inga dolda avgifter. Välj din hyresperiod och kör.</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal-on-scroll delay-100">
				<!-- 1 dag -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 text-center hover:-translate-y-1 hover:shadow-lg transition-all duration-300 border border-slate-200/80">
					<div class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">1 dag</div>
					<div class="text-4xl font-extrabold text-text-heading mb-1">1 000 <span class="text-lg font-bold text-slate-400">kr</span></div>
					<p class="text-xs text-text-muted mt-3">Inkl. 130 km, sedan 6 kr/km</p>
					<a href="/contact?service=lastbil&package=1_day" class="mt-6 inline-flex items-center justify-center gap-2 w-full px-5 py-3 rounded-lg border border-accent text-accent font-bold text-sm hover:bg-accent hover:text-white transition-colors">
						Boka nu
					</a>
				</div>

				<!-- 3 dagar (populär) -->
				<div class="relative glow-card rounded-2xl p-8 text-center bg-gradient-to-br from-teal-700 to-emerald-800 text-white shadow-xl hover:-translate-y-1 transition-all duration-300 border border-teal-600/50">
					<div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-amber-400 text-amber-900 text-[10px] font-extrabold px-3 py-1 rounded-full uppercase tracking-wider">Populärast</div>
					<div class="text-sm font-bold text-teal-200 uppercase tracking-wider mb-2">3 dagar</div>
					<div class="text-4xl font-extrabold text-white mb-1">2 100 <span class="text-lg font-bold text-teal-200">kr</span></div>
					<p class="text-xs text-teal-100/80 mt-3">Inkl. 130 km, sedan 6 kr/km</p>
					<a href="/contact?service=lastbil&package=3_days" class="mt-6 inline-flex items-center justify-center gap-2 w-full px-5 py-3 rounded-lg bg-white text-teal-900 font-bold text-sm hover:bg-teal-50 transition-colors shadow-xs active:scale-[0.98]">
						Boka nu
					</a>
				</div>

				<!-- 7 dagar -->
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 text-center hover:-translate-y-1 hover:shadow-lg transition-all duration-300 border border-slate-200/80">
					<div class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">7 dagar</div>
					<div class="text-4xl font-extrabold text-text-heading mb-1">4 500 <span class="text-lg font-bold text-slate-400">kr</span></div>
					<p class="text-xs text-text-muted mt-3">Inkl. 130 km, sedan 6 kr/km</p>
					<a href="/contact?service=lastbil&package=7_days" class="mt-6 inline-flex items-center justify-center gap-2 w-full px-5 py-3 rounded-lg border border-accent text-accent font-bold text-sm hover:bg-accent hover:text-white transition-colors">
						Boka nu
					</a>
				</div>
			</div>

			<!-- Custom Period Note -->
			<div class="mt-8 text-center reveal-on-scroll">
				<p class="text-xs text-text-muted">
					Behöver du en annan hyresperiod? <a href="/contact?service=lastbil&package=other" class="text-accent hover:underline font-semibold">Kontakta oss för en anpassad offert</a>.
				</p>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ ADVANTAGES ═══════════════════ -->
	<section class="py-20 bg-surface-warm relative">
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>
		<div class="max-w-6xl mx-auto px-6">
			<div class="max-w-2xl mb-14 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Fördelar</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">Varför hyra från oss?</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 reveal-on-scroll">
					<div class="text-3xl mb-4">🚛</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Modern Iveco Daily 2019</h3>
					<p class="text-sm text-text-body leading-relaxed">Bekväm och pålitlig lastbil med automatväxel och låg bränsleförbrukning.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 reveal-on-scroll delay-100">
					<div class="text-3xl mb-4">⬆️</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Baklyft ingår</h3>
					<p class="text-sm text-text-body leading-relaxed">Praktisk för lastning av tunga föremål utan risk för rygg- eller axelskador.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 reveal-on-scroll delay-200">
					<div class="text-3xl mb-4">🪪</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">B-körkort räcker</h3>
					<p class="text-sm text-text-body leading-relaxed">Du behöver inget speciellt körkort för att hyra och köra vår lastbil.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 reveal-on-scroll delay-100">
					<div class="text-3xl mb-4">📅</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Flexibla hyresperioder</h3>
					<p class="text-sm text-text-body leading-relaxed">Hyr för 1, 3 eller 7 dagar till fasta priser. Längre perioder kan ordnas vid behov.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 reveal-on-scroll delay-200">
					<div class="text-3xl mb-4">🛡️</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Försäkring ingår</h3>
					<p class="text-sm text-text-body leading-relaxed">Fordonet är försäkrat upp till 300 000 kr med en självrisk på 5 000 kr. Assistans ingår.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 reveal-on-scroll delay-300">
					<div class="text-3xl mb-4">🛣️</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">130 km fri körning</h3>
					<p class="text-sm text-text-body leading-relaxed">Generös fri körning, därefter bara 6 kr/km. Perfekt för de flesta uppdrag.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ GALLERY & DETAILS ═══════════════════ -->
	<section class="py-20 bg-white relative overflow-hidden bg-grid-pattern border-t border-slate-100">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div class="reveal-on-scroll">
					<div class="tilt-card rounded-2xl overflow-hidden aspect-[4/3] bg-slate-50 border border-slate-200/60 shadow-md">
						<img src={truck2Img.src} alt="Iveco Daily 2019 interiör" class="w-full h-full object-cover transition-transform duration-700 tilt-inner" />
					</div>
				</div>
				<div class="space-y-8 reveal-on-scroll delay-200">
					<div>
						<span class="text-xs font-bold text-accent uppercase tracking-widest">Fordonsinformation</span>
						<h2 class="text-2xl md:text-3xl font-bold text-text-heading tracking-tight mt-3 mb-4">Iveco Daily 35-160</h2>
						<p class="text-text-body leading-relaxed">Chassis Cab 2.3 JTD Hi-Matic 2019. Automatväxel, rymlig lastyta och enkel att köra med vanligt B-körkort. Perfekt för flytt, möbelhämtning eller materialtransport.</p>
					</div>
					
					<div class="space-y-4">
						<div class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 border border-slate-100">
							<span class="text-xl">🛡️</span>
							<div>
								<h4 class="text-sm font-bold text-text-heading">Självrisk</h4>
								<p class="text-xs text-text-body mt-0.5">Fordon är täckta för skador upp till 300 000 kr med en självrisk för hyrestagaren på 5 000 kr. Vägassistans ingår utan självrisk.</p>
							</div>
						</div>
						<div class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 border border-slate-100">
							<span class="text-xl">📋</span>
							<div>
								<h4 class="text-sm font-bold text-text-heading">Avbokningspolicy</h4>
								<p class="text-xs text-text-body mt-0.5">Avbokning minst 2 dagar innan: full återbetalning. Dagen innan: 50% återbetalning. Samma dag: ingen återbetalning.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ USE CASES ═══════════════════ -->
	<section class="py-20 bg-surface-cool border-t border-slate-100">
		<div class="max-w-5xl mx-auto px-6">
			<div class="text-center mb-14 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest">Användningsområden</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">När passar en lätt lastbil?</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 reveal-on-scroll delay-100">
				<div class="flex items-start gap-4 p-5 rounded-xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md transition-shadow">
					<span class="text-2xl">📦</span>
					<div><h4 class="font-bold text-text-heading text-sm">Flytt</h4><p class="text-xs text-text-body mt-1">Inom Kronoberg/Kalmar eller till annan ort – transportera allt i en tur.</p></div>
				</div>
				<div class="flex items-start gap-4 p-5 rounded-xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md transition-shadow">
					<span class="text-2xl">🛋️</span>
					<div><h4 class="font-bold text-text-heading text-sm">Möbelhämtning</h4><p class="text-xs text-text-body mt-1">Hämta nya möbler från butik eller privatförsäljare.</p></div>
				</div>
				<div class="flex items-start gap-4 p-5 rounded-xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md transition-shadow">
					<span class="text-2xl">🌿</span>
					<div><h4 class="font-bold text-text-heading text-sm">Trädgårdsavfall</h4><p class="text-xs text-text-body mt-1">Kör trädgårdsavfall till återvinningen enkelt.</p></div>
				</div>
				<div class="flex items-start gap-4 p-5 rounded-xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md transition-shadow">
					<span class="text-2xl">🔨</span>
					<div><h4 class="font-bold text-text-heading text-sm">Renovering</h4><p class="text-xs text-text-body mt-1">Transportera byggmaterial under renoveringsprojekt.</p></div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ CTA ═══════════════════ -->
	<section class="py-20 bg-[#040a18] relative">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
		<div class="max-w-3xl mx-auto px-6 text-center reveal-on-scroll">
			<h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-5">Redo att boka?</h2>
			<p class="text-slate-400 text-base leading-relaxed mb-8 max-w-lg mx-auto">Kontakta oss via telefon eller e-post så ordnar vi din hyrbil snabbt. Boka i god tid för att säkra tillgänglighet under helger och högsäsong.</p>
			<div class="flex flex-wrap items-center justify-center gap-4">
				<a href="/contact?service=lastbil" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-lg shadow-teal-900/30">
					Kontakta oss
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
				</a>
				<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-700 text-sm font-bold text-slate-300 hover:bg-slate-800 transition-colors">
					📞 Ring 08-123 45 67
				</a>
			</div>
		</div>
	</section>

</main>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		if (window.initGlowCards) window.initGlowCards();
		if (window.initTiltCards) window.initTiltCards();

		// --- Word Cycler Logic ---
		const words = document.querySelectorAll('.cycling-word');
		if (words.length > 1) {
			let wordIdx = 0;
			setInterval(() => {
				words[wordIdx].classList.remove('active');
				wordIdx = (wordIdx + 1) % words.length;
				words[wordIdx].classList.add('active');
			}, 2500);
		}
	});
</script>
</Layout>
