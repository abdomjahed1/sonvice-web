<script>
	// FAQ Accordion logic
	document.querySelectorAll('.faq-toggle').forEach(button => {
		button.addEventListener('click', () => {
			const answer = button.nextElementSibling;
			const icon = button.querySelector('svg');
			
			const isOpen = !answer?.classList.contains('hidden');
			
			// Close all other FAQs
			document.querySelectorAll('.faq-answer').forEach(el => el.classList.add('hidden'));
			document.querySelectorAll('.faq-toggle svg').forEach(el => el.classList.remove('rotate-180'));
			
			if (!isOpen && answer && icon) {
				answer.classList.remove('hidden');
				icon.classList.add('rotate-180');
			}
		});
	});

	// Word Cycling Animation
	const cyclingWords = document.querySelectorAll('.cycling-word');
	if (cyclingWords.length > 0) {
		let currentIndex = 0;
		setInterval(() => {
			cyclingWords[currentIndex].classList.remove('active');
			currentIndex = (currentIndex + 1) % cyclingWords.length;
			cyclingWords[currentIndex].classList.add('active');
		}, 2500);
	}
</script>
