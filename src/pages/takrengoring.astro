---
import Layout from '../layouts/Layout.astro';
import takrengoringImg from '../images/Takrengöring.jpg';
---

<Layout title="Takrengöring Kronoberg/Kalmar | Mossa & Algbehandling | Sonvice Group" description="Professionell takrengöring i Kronoberg/Kalmar. Vi tar bort mossa, alger och lav samt behandlar taket för att förhindra återväxt. Skatteavdrag med ROT-avdrag.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO ═══════════════════ -->
	<section class="relative bg-white pt-12 pb-20 md:py-28 bg-grid-pattern">
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] -z-10 pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[30%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] -z-10 pointer-events-none animate-float-delay"></div>

		<div class="max-w-6xl mx-auto px-6">
		<!-- Back button -->
		<div class="mb-8 reveal-on-scroll">
			<a href="/#services" class="inline-flex items-center gap-2 text-sm font-bold text-slate-600 hover:text-accent transition-colors group">
				<svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
				</svg>
				Tillbaka till tjänster
			</a>
		</div>
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
				
				<div class="lg:col-span-7 space-y-7 reveal-on-scroll">
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Förläng takets livslängd</span>
					</div>
					
					<h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight text-text-heading leading-[1.08]">
						<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
							<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Skonsam</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Hållbar</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Professionell</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Effektiv</span>
						</span>
						<span class="block bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">takrengöring i Kronoberg/Kalmar</span>
					</h1>
					
					<p class="text-lg text-text-body leading-relaxed max-w-xl">
						Låt inte mossan förstöra ditt tak. Vi rengör tegel- och betongpannor från mossa, alger, lav och smuts samt behandlar taket med marknadsledande anti-algblandning för att förhindra återväxt i upp till 4–5 år. Ett rent tak förebygger frostsprickor och kostsamma läckor.
					</p>

					<div class="flex flex-wrap items-center gap-4 pt-2">
						<a href="/contact?service=takrengoring" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm">
							Begär gratis offert
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Ring 08-123 45 67
						</a>
					</div>

					<div class="flex flex-wrap items-center gap-x-6 gap-y-3 pt-5 border-t border-slate-100 text-sm text-slate-600">
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
							Trygg-Hansa ansvarsförsäkrad
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							30% ROT-avdrag direkt
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							Förebygger vattenskador
						</span>
					</div>
				</div>

				<div class="lg:col-span-5 relative reveal-on-scroll delay-200">
					<div class="absolute -inset-4 border border-dashed border-slate-200/80 rounded-3xl -z-10 pointer-events-none"></div>
					<div class="tilt-card rounded-2xl overflow-hidden aspect-[4/3] bg-slate-50 border border-slate-200/60 shadow-md">
						<img src={takrengoringImg.src} width={takrengoringImg.width} height={takrengoringImg.height} alt="Professionell mossborttagning på betongtak" class="w-full h-full object-cover transition-transform duration-700 tilt-inner" />
					</div>
					<div class="absolute -bottom-6 -left-6 md:bottom-8 md:-left-8 glass-panel rounded-xl shadow-lg p-5 border border-slate-200/80 max-w-[200px]">
						<div class="text-2xl font-extrabold text-accent">fr. 3 150 kr</div>
						<div class="text-xs text-text-heading font-bold uppercase tracking-wider mt-1">Efter ROT-avdrag</div>
						<p class="text-[10px] text-text-muted mt-1 leading-normal">Minsta debitering (4 500 kr före ROT).</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ ARBETSPROCESS ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden border-t border-slate-100">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest font-mono">Arbetsmetod</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">Hur rengör vi ditt tak?</h2>
				<p class="text-text-body text-base">Vi arbetar systematiskt och säkert med modern utrustning och fallskydd.</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 reveal-on-scroll delay-100">
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">1. Besiktning</h3>
					<p class="text-xs text-text-body leading-relaxed">Vi kontrollerar takets skick, identifierar spruckna pannor och ser till att läkt och underlagspapp är intakta innan vi påbörjar arbetet.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">2. Högtrycksspolning</h3>
					<p class="text-xs text-text-body leading-relaxed">Vi spolar rent taket uppifrån och ner med ett anpassat vattentryck som tar bort all mossa och lav mekaniskt utan att skada pannornas ytskikt.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707.707M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">3. Algbehandling</h3>
					<p class="text-xs text-text-body leading-relaxed">Vi sprayar på ett biologiskt nedbrytbart algmedel. Det tränger djupt ner i pannornas porer och dödar de sista mikroskopiska rötterna av alger och lav.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">4. Uppstädning</h3>
					<p class="text-xs text-text-body leading-relaxed">Vi rensar hängrännor från spolrester och städar upp allt nedfallet skräp runt huset. Vi lämnar din fastighet i toppskick.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ ROT-AVDRAG INFO ═══════════════════ -->
	<section class="py-20 bg-surface-warm relative border-t border-slate-100">
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>
		<div class="max-w-5xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 space-y-6 reveal-on-scroll">
					<span class="text-xs font-bold text-accent uppercase tracking-widest">ROT-avdrag</span>
					<h2 class="text-3xl font-bold text-text-heading tracking-tight">ROT-avdrag på taktvätt</h2>
					<p class="text-sm text-text-body leading-relaxed">
						Takrengöring är en underhållstjänst på fastigheten som ger rätt till <strong>30% ROT-avdrag</strong> på arbetskostnaden. Vi drar av skatterabatten direkt på din faktura och ansöker hos Skatteverket. Du behöver bara tillhandahålla din fastighetsbeteckning samt personnummer vid bokning.
					</p>
					<div class="space-y-3 text-xs text-text-body">
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Vi drar av 30% av arbetskostnaden direkt på fakturan.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Vi sköter ansökan hos Skatteverket utan extra avgifter.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Minsta debitering är 4 500 kr före ROT (3 150 kr efter ROT-avdrag).</span>
						</div>
					</div>
				</div>
				<div class="lg:col-span-6 reveal-on-scroll delay-200">
					<div class="bg-white rounded-2xl border border-slate-200/80 shadow-xs overflow-hidden">
						<!-- Highlighted Price Header -->
						<div class="bg-gradient-to-r from-teal-50 to-emerald-50/30 p-6 border-b border-slate-100 text-center">
							<span class="text-xs font-bold text-accent uppercase tracking-widest block mb-1">Prisexempel (Tak på 120 kvm)</span>
							<div class="text-3xl font-extrabold text-text-heading">5 694 kr</div>
							<p class="text-xs text-text-muted mt-1">Efter 30% ROT-avdrag (inkl. moms & material)</p>
						</div>
						
						<!-- Price Breakdown Details -->
						<div class="p-6 space-y-4">
							<div class="text-xs text-text-muted font-bold uppercase tracking-wider mb-2">Kostnadsfördelning</div>
							
							<div class="space-y-3 text-sm">
								<div class="flex justify-between text-text-body">
									<span>Taktvätt & behandling <span class="text-xs text-text-muted block mt-0.5">(120 kvm á 56 kr/kvm)</span></span>
									<span class="font-semibold text-text-heading">6 720 kr</span>
								</div>
								
								<div class="flex justify-between text-text-body">
									<span>Ställnings- & etableringsavgift <span class="text-xs text-text-muted block mt-0.5">(ej berättigad till ROT)</span></span>
									<span class="font-semibold text-text-heading">990 kr</span>
								</div>
								
								<div class="flex justify-between text-teal-600 font-medium pt-2 border-t border-slate-100">
									<span>ROT-avdrag <span class="text-xs text-teal-500">(30% skatterabatt på arbete)</span></span>
									<span class="font-semibold">-2 016 kr</span>
								</div>
							</div>
							
							<div class="bg-slate-50 rounded-xl p-4 mt-4 text-center">
								<p class="text-xs text-text-body leading-relaxed">
									Priset inkluderar moms, städmaterial och etablering. Vi sköter ansökan hos Skatteverket utan extra avgifter.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ FAQ ═══════════════════ -->
	<section class="bg-white py-20 md:py-28 border-t border-slate-100">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest font-mono">FAQ</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-2 mb-4">Vanliga frågor om takrengöring</h2>
			</div>

			<div class="space-y-1 reveal-on-scroll">
				{[
					{
						q: 'Varför är det skadligt att ha mossa på taket?',
						a: 'Mossa fungerar som en svamp som drar till sig och håller kvar fukt mot takpannorna. När vintern kommer fryser fukten till is, vilket leder till frostsprickor i pannorna. Sprickorna gör att vatten kan tränga igenom till läkten och underlagspappen, vilket i sin tur leder till dyra vattenskador och röta i takstolen.'
					},
					{
						q: 'Hur ofta behöver man rengöra taket?',
						a: 'Ett tak som rengörs mekaniskt och därefter behandlas med kemiskt algskydd håller sig vanligtvis fritt från mossa och alger i 4 till 6 år, beroende på husets läge (skugga från träd ökar mossbildning). Vi rekommenderar en översyn och förebyggande behandling vart femte år.'
					},
					{
						q: 'Skadas takpannorna av högtryckstvätt?',
						a: 'Nej, inte när det utförs på rätt sätt av proffs. Vi justerar vattentrycket efter takpannornas ålder och material (betong eller tegel). Vi spolar dessutom alltid uppifrån och ner för att förhindra att vatten pressas in under takpannorna.'
					},
					{
						q: 'Ingår rensning av hängrännor?',
						a: 'Ja, absolut. När vi spolar rent taket hamnar skräp och mossa i hängrännorna. Vi rensar alltid hängrännorna grundligt och ser till att stuprören inte är igentäppta innan vi avslutar uppdraget.'
					}
				].map((faq, idx) => (
					<div class="border-b border-slate-100 last:border-b-0">
						<button
							id={`faq-btn-${idx}`}
							class="faq-trigger w-full flex justify-between items-center py-5 text-left font-bold text-text-heading hover:text-accent transition-colors cursor-pointer outline-none group"
							aria-expanded="false"
						>
							<span class="text-base md:text-lg pr-4">{faq.q}</span>
							<span class="faq-icon text-text-muted flex-shrink-0 transition-transform duration-300 group-aria-expanded:rotate-180">
								<svg class="w-5 h-5 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
							</span>
						</button>
						<div id={`faq-content-${idx}`} class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
							<div class="pb-5 text-text-body text-base leading-relaxed">
								{faq.a}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══════════════════ CTA ═══════════════════ -->
	<section class="py-20 bg-[#040a18] relative">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
		<div class="max-w-3xl mx-auto px-6 text-center reveal-on-scroll">
			<h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-5">Skydda ditt tak idag</h2>
			<p class="text-slate-400 text-base leading-relaxed mb-8 max-w-lg mx-auto">Hör av dig till oss för en kostnadsfri takbesiktning och offert. Vi ger dig ett fast pris på rengöring och mossbehandling.</p>
			<div class="flex flex-wrap items-center justify-center gap-4">
				<a href="/contact?service=takrengoring" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-lg shadow-teal-900/30">
					Begär kostnadsfri offert
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
				</a>
				<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-700 text-sm font-bold text-slate-300 hover:bg-slate-800 transition-colors">
					Ring oss
				</a>
			</div>
		</div>
	</section>

</main>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (window.initGlowCards) window.initGlowCards();
		if (window.initTiltCards) window.initTiltCards();

		// --- Word Cycler Logic ---
		const words = document.querySelectorAll('.cycling-word');
		if (words.length > 1) {
			let wordIdx = 0;
			setInterval(() => {
				words[wordIdx].classList.remove('active');
				wordIdx = (wordIdx + 1) % words.length;
				words[wordIdx].classList.add('active');
			}, 2500);
		}

		// FAQ accordion toggle
		document.querySelectorAll('.faq-trigger').forEach(trigger => {
			trigger.addEventListener('click', () => {
				const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
				const contentId = trigger.id.replace('btn', 'content');
				const content = document.getElementById(contentId);

				document.querySelectorAll('.faq-trigger').forEach(ot => {
					if (ot !== trigger) {
						ot.setAttribute('aria-expanded', 'false');
						const oId = ot.id.replace('btn', 'content');
						const oC = document.getElementById(oId);
						if (oC) oC.style.maxHeight = null;
					}
				});

				trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
				if (content) content.style.maxHeight = isExpanded ? null : content.scrollHeight + 'px';
			});
		});
	});
</script>
</Layout>
