---
import Layout from '../layouts/Layout.astro';
import tradgardsvardImg from '../images/Trädgårdsvård.png';
---

<Layout title="Trädgårdsvård Kronoberg/Kalmar | Gräsklippning & Häckklippning | Sonvice Group" description="Professionell trädgårdsvård i Kronoberg/Kalmar för privatpersoner. Gräsklippning, häckklippning, ogräsrensning och beskärning med direkt RUT-avdrag på fakturan.">
<main class="relative overflow-hidden">

	<!-- ═══════════════════ HERO ═══════════════════ -->
	<section class="relative bg-white pt-12 pb-20 md:py-28 bg-grid-pattern">
		<div class="absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-glow-teal rounded-full blur-[90px] -z-10 pointer-events-none animate-float-slow"></div>
		<div class="absolute top-[30%] right-[10%] w-[350px] h-[350px] bg-glow-amber rounded-full blur-[70px] -z-10 pointer-events-none animate-float-delay"></div>

		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
				
				<div class="lg:col-span-7 space-y-7 reveal-on-scroll">
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200/80 shadow-xs">
						<span class="text-xs font-bold text-slate-600 tracking-wider uppercase">Grön och välskött trädgård</span>
					</div>
					
					<h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight text-text-heading leading-[1.08]">
						<span class="cycling-word-container text-accent inline-block mr-2 align-bottom">
							<span class="cycling-word active bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Professionell</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Välskött</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Grön</span>
							<span class="cycling-word bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">Vacker</span>
						</span>
						<span class="block bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">trädgårdsvård i Kronoberg/Kalmar</span>
					</h1>
					
					<p class="text-lg text-text-body leading-relaxed max-w-xl">
						Håll din trädgård fin och välvårdad hela säsongen utan att lyfta ett finger. Vi erbjuder allt från regelbunden gräsklippning och häckklippning till ogräsrensning, krattning, lövblåsning och trädgårdsstädning – med RUT-avdrag direkt.
					</p>

					<div class="flex flex-wrap items-center gap-4 pt-2">
						<a href="/contact?service=tradgard" class="inline-flex items-center gap-2 px-7 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-sm">
							Begär gratis offert
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</a>
						<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-200 bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-colors">
							Ring 08-123 45 67
						</a>
					</div>

					<div class="flex flex-wrap items-center gap-x-6 gap-y-3 pt-5 border-t border-slate-100 text-sm text-slate-500">
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
							Trygg-Hansa försäkrad
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
							50% RUT-avdrag på arbetet
						</span>
						<span class="flex items-center gap-2 font-medium">
							<svg class="w-4.5 h-4.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							Professionella verktyg ingår
						</span>
					</div>
				</div>

				<div class="lg:col-span-5 relative reveal-on-scroll delay-200">
					<div class="absolute -inset-4 border border-dashed border-slate-200/80 rounded-3xl -z-10 pointer-events-none"></div>
					<div class="tilt-card rounded-2xl overflow-hidden aspect-[4/3] bg-slate-50 border border-slate-200/60 shadow-md">
						<img src={tradgardsvardImg.src} alt="Gräsklippning och skötsel av trädgård" class="w-full h-full object-cover transition-transform duration-700 tilt-inner" />
					</div>
					<div class="absolute -bottom-6 -left-6 md:bottom-8 md:-left-8 glass-panel rounded-xl shadow-lg p-5 border border-slate-200/80 max-w-[200px]">
						<div class="text-2xl font-extrabold text-accent">fr. 295 kr</div>
						<div class="text-xs text-text-heading font-bold uppercase tracking-wider mt-1">per timme</div>
						<p class="text-[10px] text-text-muted mt-1 leading-normal">Efter RUT-avdrag (inkl. moms & maskiner).</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ VAD INGÅR ═══════════════════ -->
	<section class="py-20 md:py-28 bg-surface-cool relative overflow-hidden border-t border-slate-100">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest font-mono">Tjänsteomfattning</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-3 mb-4">Vad kan vi hjälpa till med?</h2>
				<p class="text-text-body text-base leading-relaxed">Vi sköter om trädgårdens alla sysslor under hela växtsäsongen.</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 reveal-on-scroll delay-100">
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M2 22c1.25-5.833 3.75-9.333 7.5-10.5M22 22c-1.25-5.833-3.75-9.333-7.5-10.5"></path>
							<path d="M12 2v20"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Gräsklippning</h3>
					<p class="text-xs text-text-body leading-relaxed">Regelbunden eller engångsklippning samt trimning av kanter runt träd, rabatter och gångar.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="6" cy="6" r="3"></circle>
							<circle cx="6" cy="18" r="3"></circle>
							<line x1="9.8" y1="8.2" x2="20" y2="17"></line>
							<line x1="9.8" y1="15.8" x2="20" y2="7"></line>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Häckklippning</h3>
					<p class="text-xs text-text-body leading-relaxed">Professionell formklippning av löv- och barrhäckar. Vi ser till att häckarna hålls täta och prydliga.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707.707M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Trädgårdsstädning</h3>
					<p class="text-xs text-text-body leading-relaxed">Rensning av ogräs i rabatter och grusgångar, krattning av löv samt rensning inför vår/höst.</p>
				</div>
				<div class="glow-card glass-panel bg-white/90 rounded-2xl p-7 hover:-translate-y-1 transition-all border border-slate-200/80">
					<div class="w-12 h-12 rounded-xl bg-teal-50 border border-teal-100/80 flex items-center justify-center mb-5 text-accent">
						<svg class="w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2a5 5 0 0 0-5 5c0 2.5 1.5 4.5 4 4.8V22h2V11.8c2.5-.3 4-2.3 4-4.8a5 5 0 0 0-5-5z"></path>
						</svg>
					</div>
					<h3 class="text-lg font-bold text-text-heading mb-2">Beskärning</h3>
					<p class="text-xs text-text-body leading-relaxed">Enklare beskärning av buskar och mindre fruktträd (JAS-perioden eller under vårvintern) för rikligare skörd.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ PRIS & RUT ═══════════════════ -->
	<section class="py-20 bg-surface-warm relative border-t border-slate-100">
		<div class="absolute bottom-0 right-10 w-[450px] h-[450px] bg-glow-amber rounded-full blur-[100px] pointer-events-none"></div>
		<div class="max-w-5xl mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 space-y-6 reveal-on-scroll">
					<span class="text-xs font-bold text-accent uppercase tracking-widest">RUT-avdrag</span>
					<h2 class="text-3xl font-bold text-text-heading tracking-tight">RUT-avdrag för trädgårdsskötsel</h2>
					<p class="text-sm text-text-body leading-relaxed">
						Trädgårdsarbete som gräsklippning, häckklippning, ogräsrensning och beskärning av träd ger rätt till <strong>50% RUT-avdrag</strong> på arbetskostnaden. Det gör det mycket prisvärt att ta hjälp med grovarbetet. Vi sköter all administration med Skatteverket och drar av rabatten direkt på fakturan.
					</p>
					<div class="space-y-3 text-xs text-text-body">
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Vi tar med egna bensingräsklippare, häcksaxar, lövblåsar och trimmers.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Tillval: Vi kan transportera bort allt trädgårdsavfall till återvinningen.</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="text-emerald-600">✓</span> <span>Vi erbjuder flexibla abonnemangsavtal för skötsel under hela säsongen.</span>
						</div>
					</div>
				</div>
				<div class="lg:col-span-6 reveal-on-scroll delay-200">
					<div class="bg-white rounded-2xl p-8 border border-slate-200/80 shadow-xs space-y-4">
						<h3 class="font-bold text-text-heading text-lg">Prisexempel (efter RUT)</h3>
						<div class="space-y-3 text-xs">
							<div class="flex justify-between border-b border-slate-100 pb-2">
								<span>Löpande gräsklippning (varje/varannan vecka)</span>
								<span class="font-bold text-accent">fr. 295 kr/tim</span>
							</div>
							<div class="flex justify-between border-b border-slate-100 pb-2">
								<span>Häckklippning (engångsuppdrag, medelstor villahäck)</span>
								<span class="font-bold text-accent">fr. 1 190 kr fast</span>
							</div>
							<div class="flex justify-between border-b border-slate-100 pb-2">
								<span>Trädgårdsstädning (vår/höststädning, 4 timmar, 1 person)</span>
								<span class="font-bold text-accent">fr. 1 180 kr</span>
							</div>
							<div class="text-[10px] text-text-muted">
								* Priserna inkluderar moms och är efter 50% RUT-avdrag. Maskinslitage och drivmedel ingår. Eventuell bortforsling av avfall tillkommer som fast avgift.
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════ FAQ ═══════════════════ -->
	<section class="bg-white py-20 md:py-28 border-t border-slate-100">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-16 reveal-on-scroll">
				<span class="text-xs font-bold text-accent uppercase tracking-widest font-mono">FAQ</span>
				<h2 class="text-3xl md:text-4xl font-bold text-text-heading tracking-tight mt-2 mb-4">Vanliga frågor om trädgårdsvård</h2>
			</div>

			<div class="space-y-1 reveal-on-scroll">
				{[
					{
						q: 'Tar ni med egna trädgårdsmaskiner och verktyg?',
						a: 'Ja, vi tar med oss alla maskiner (gräsklippare, trimmer, häcksax, lövblås) samt handverktyg som behövs för uppdraget. Drivmedel och elsladdar ingår i timpriset.'
					},
					{
						q: 'Transporterar ni bort trädgårdsavfallet?',
						a: 'Ja, som tillval kan vi samla ihop och transportera bort allt gren-, löv- och gräsklippsavfall till närmaste återvinningscentral. Vi debiterar en fast avgift för bil och tippavgift.'
					},
					{
						q: 'Erbjuder ni abonnemang för gräsklippning?',
						a: 'Ja, vi kan lägga upp ett skräddarsytt skötselschema där vi besöker dig t.ex. varje vecka eller varannan vecka för att hålla gräsmattan och rabatterna i perfekt skick hela sommaren.'
					},
					{
						q: 'Ger trädfällning rätt till RUT-avdrag?',
						a: 'Ja, fällning, beskärning och sektionsfällning av träd och buskar på tomten ger rätt till RUT-avdrag (50%). Bortforsling av stammar och grenar berättigar dock inte till RUT-avdrag, utan debiteras till ordinarie pris.'
					}
				].map((faq, idx) => (
					<div class="border-b border-slate-100 last:border-b-0">
						<button
							id={`faq-btn-${idx}`}
							class="faq-trigger w-full flex justify-between items-center py-5 text-left font-bold text-text-heading hover:text-accent transition-colors cursor-pointer outline-none group"
							aria-expanded="false"
						>
							<span class="text-base md:text-lg pr-4">{faq.q}</span>
							<span class="faq-icon text-text-muted flex-shrink-0 transition-transform duration-300 group-aria-expanded:rotate-180">
								<svg class="w-5 h-5 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
							</span>
						</button>
						<div id={`faq-content-${idx}`} class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
							<div class="pb-5 text-text-body text-base leading-relaxed">
								{faq.a}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══════════════════ CTA ═══════════════════ -->
	<section class="py-20 bg-[#040a18] relative">
		<div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
		<div class="max-w-3xl mx-auto px-6 text-center reveal-on-scroll">
			<h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-5">Få en grönskande trädgård utan besvär</h2>
			<p class="text-slate-400 text-base leading-relaxed mb-8 max-w-lg mx-auto">Kontakta oss idag för att berätta vad du behöver hjälp med i din trädgård, så återkommer vi med en kostnadsfri offert.</p>
			<div class="flex flex-wrap items-center justify-center gap-4">
				<a href="/contact?service=tradgard" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-accent text-white font-bold text-sm hover:bg-accent-hover active:scale-[0.98] transition-all shadow-lg shadow-teal-900/30">
					Kontakta oss för offert
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
				</a>
				<a href="tel:081234567" class="inline-flex items-center gap-2 px-6 py-4 rounded-lg border border-slate-700 text-sm font-bold text-slate-300 hover:bg-slate-800 transition-colors">
					Ring oss
				</a>
			</div>
		</div>
	</section>

</main>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (window.initGlowCards) window.initGlowCards();
		if (window.initTiltCards) window.initTiltCards();

		// --- Word Cycler Logic ---
		const words = document.querySelectorAll('.cycling-word');
		if (words.length > 1) {
			let wordIdx = 0;
			setInterval(() => {
				words[wordIdx].classList.remove('active');
				wordIdx = (wordIdx + 1) % words.length;
				words[wordIdx].classList.add('active');
			}, 2500);
		}

		// FAQ accordion toggle
		document.querySelectorAll('.faq-trigger').forEach(trigger => {
			trigger.addEventListener('click', () => {
				const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
				const contentId = trigger.id.replace('btn', 'content');
				const content = document.getElementById(contentId);

				document.querySelectorAll('.faq-trigger').forEach(ot => {
					if (ot !== trigger) {
						ot.setAttribute('aria-expanded', 'false');
						const oId = ot.id.replace('btn', 'content');
						const oC = document.getElementById(oId);
						if (oC) oC.style.maxHeight = null;
					}
				});

				trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
				if (content) content.style.maxHeight = isExpanded ? null : content.scrollHeight + 'px';
			});
		});
	});
</script>
</Layout>
